<?php

namespace App\Http\Controllers;

use App\Models\Driver;
use App\Models\GlobalKilometerReport;
use App\Models\Holiday;
use App\Models\KilometerReport;
use App\Models\MaintenanceLog;
use App\Models\Route;
use App\Models\Schedule;
use App\Models\Unit;
use Carbon\Carbon;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\View;
use Maatwebsite\Excel\Facades\Excel;
use Maatwebsite\Excel\Concerns\FromView;
use Maatwebsite\Excel\Concerns\WithTitle;
use Maatwebsite\Excel\Concerns\WithStyles;
use PhpOffice\PhpSpreadsheet\Worksheet\Worksheet;
use PhpOffice\PhpSpreadsheet\Cell\Coordinate;
use Barryvdh\DomPDF\Facade\Pdf;

class GlobalKilometerReportController extends Controller
{
    public function index(Request $request)
    {
        $period = (int)$request->input('period', 1); // Default to period 1
        $month = (int)$request->input('month', Carbon::now()->month);
        $year = (int)$request->input('year', Carbon::now()->year);
        
        $currentMonth = Carbon::createFromDate($year, $month, 1);
        
        if ($period == 1) {
            $startDate = $currentMonth->copy()->format('Y-m-d');
            $endDate = $currentMonth->copy()->addDays(14)->format('Y-m-d');
        } else {
            $startDate = $currentMonth->copy()->addDays(15)->format('Y-m-d');
            $endDate = $currentMonth->copy()->endOfMonth()->format('Y-m-d');
        }
        
        $hasReports = GlobalKilometerReport::where('period', $period)
            ->where('month', $month)
            ->where('year', $year)
            ->exists();
        
        $routeGroups = Route::select('route_number')
            ->distinct()
            ->whereNotNull('route_number')
            ->where('route_number', '!=', '')
            ->orderBy('route_number')
            ->pluck('route_number')
            ->toArray();
            
        $defaultGroup = !empty($routeGroups) ? $routeGroups[0] : 'all';
        $activeRouteGroup = $request->input('group', $defaultGroup);
        
        $routeGroups[] = 'all';
        
        if ($activeRouteGroup !== 'all') {
            $routes = Route::where('route_number', $activeRouteGroup)
                ->with('units')
                ->orderBy('route_number')
                ->get();
        } else {
            $routes = Route::with('units')
                ->orderBy('route_number')
                ->get();
        }
        
        $dates = [];
        $currentDate = Carbon::parse($startDate);
        $lastDate = Carbon::parse($endDate);
        
        while ($currentDate->lte($lastDate)) {
            $dates[] = $currentDate->format('Y-m-d');
            $currentDate->addDay();
        }
        
        $dates = [];
        $currentDate = Carbon::parse($startDate);
        $lastDate = Carbon::parse($endDate);
        
        while ($currentDate->lte($lastDate)) {
            $dates[] = $currentDate->format('Y-m-d');
            $currentDate->addDay();
        }
        
        $drivers = Driver::active()->get()->keyBy('id');
        $units = Unit::with('drivers')->get()->keyBy('id');
        
        $routeTotals = [];
        $unitTotals = [];
        $driverTotals = [];
        $dateTotals = [];
        $routeUnitTotals = [];
        $routeDriverTotals = [];
        
        $reportsByRouteUnitDriverDate = [];
        $driverCountByRouteUnitDate = [];
        $maintenanceUnitsByDate = [];
        $grandTotal = 0;
        
        if ($hasReports) {
            $globalReports = GlobalKilometerReport::with(['driver', 'unit', 'route'])
                ->where('period', $period)
                ->where('month', $month)
                ->where('year', $year);
                
            if ($activeRouteGroup !== 'all') {
                $globalReports->whereHas('route', function ($query) use ($activeRouteGroup) {
                    $query->where('route_number', $activeRouteGroup);
                });
            }
            
            $globalReports = $globalReports->get();
            
            foreach ($globalReports as $report) {
                $unitId = $report->unit_id;
                $routeId = $report->route_id;
                $driverId = $report->driver_id;
                $date = $report->date->format('Y-m-d');
                
                // Initialize arrays if not set
                if (!isset($reportsByRouteUnitDriverDate[$routeId])) {
                    $reportsByRouteUnitDriverDate[$routeId] = [];
                }
                
                if (!isset($reportsByRouteUnitDriverDate[$routeId][$unitId])) {
                    $reportsByRouteUnitDriverDate[$routeId][$unitId] = [];
                }
                
                if (!isset($reportsByRouteUnitDriverDate[$routeId][$unitId][$driverId])) {
                    $reportsByRouteUnitDriverDate[$routeId][$unitId][$driverId] = [];
                }
                
                $reportsByRouteUnitDriverDate[$routeId][$unitId][$driverId][$date] = $report;
                
                // Count drivers per unit per date
                if (!isset($driverCountByRouteUnitDate[$routeId][$unitId][$date])) {
                    $driverCountByRouteUnitDate[$routeId][$unitId][$date] = 0;
                }
                $driverCountByRouteUnitDate[$routeId][$unitId][$date]++;
                
                // Calculate totals
                if (!isset($routeTotals[$routeId])) {
                    $routeTotals[$routeId] = 0;
                }
                $routeTotals[$routeId] += $report->original_kilometers;
                
                if (!isset($unitTotals[$unitId])) {
                    $unitTotals[$unitId] = 0;
                }
                $unitTotals[$unitId] += $report->original_kilometers;
                
                if (!isset($driverTotals[$driverId])) {
                    $driverTotals[$driverId] = 0;
                }
                $driverTotals[$driverId] += $report->original_kilometers;
                
                if (!isset($dateTotals[$date])) {
                    $dateTotals[$date] = 0;
                }
                $dateTotals[$date] += $report->original_kilometers;
                
                if (!isset($routeUnitTotals[$routeId][$unitId])) {
                    $routeUnitTotals[$routeId][$unitId] = 0;
                }
                $routeUnitTotals[$routeId][$unitId] += $report->original_kilometers;
                
                if (!isset($routeDriverTotals[$routeId][$driverId])) {
                    $routeDriverTotals[$routeId][$driverId] = 0;
                }
                $routeDriverTotals[$routeId][$driverId] += $report->original_kilometers;
                
                $grandTotal += $report->original_kilometers;
            }
        }
        
        // Get maintenance logs for the date range
        $maintenanceLogs = MaintenanceLog::whereBetween('date_reported', [$startDate, $endDate])->get();
        foreach ($maintenanceLogs as $log) {
            $date = $log->date_reported->format('Y-m-d');
            if (!isset($maintenanceUnitsByDate[$date])) {
                $maintenanceUnitsByDate[$date] = [];
            }
            $maintenanceUnitsByDate[$date][] = $log->unit_id;
        }
        
        // Get holidays for the date range
        $holidays = Holiday::whereDate('date', '>=', $startDate)
            ->whereDate('date', '<=', $endDate)
            ->get()
            ->keyBy(function ($holiday) {
                return $holiday->date->format('Y-m-d');
            });
        
        // Get schedules for the date range
        $schedules = Schedule::whereBetween('schedule_date', [$startDate, $endDate])
            ->get()
            ->groupBy(function ($schedule) {
                return $schedule->date->format('Y-m-d');
            });
        
        $title = "Laporan Kilometer Global - ";
        $title .= "Periode " . ($period == 1 ? "1 (1-15)" : "2 (16-" . Carbon::createFromDate($year, $month, 1)->endOfMonth()->format('d') . ")");
        $title .= " " . Carbon::createFromDate($year, $month, 1)->format('F Y');
        if ($activeRouteGroup !== 'all') {
            $title .= " - Rute " . $activeRouteGroup;
        }
        
        return view('modules.admin.global-kilometer-reports.index', compact(
            'period',
            'month',
            'year',
            'routeGroups',
            'activeRouteGroup',
            'routes',
            'dates',
            'drivers',
            'units',
            'reportsByRouteUnitDriverDate',
            'driverCountByRouteUnitDate',
            'maintenanceUnitsByDate',
            'holidays',
            'schedules',
            'routeTotals',
            'unitTotals',
            'driverTotals',
            'dateTotals',
            'routeUnitTotals',
            'routeDriverTotals',
            'grandTotal',
            'title'
        ));
    }
    
    /**
     * Export global kilometer reports to Excel.
     *
     * @param Request $request
     * @return BinaryFileResponse
     */
    public function exportExcel(Request $request)
    {
        $period = $request->input('period', 1);
        $group = $request->input('group', 'all');
        $month = $request->input('month', Carbon::now()->month);
        $year = $request->input('year', Carbon::now()->year);
        
        // Use existing Blade templates for export
        
        // Get report data
        $data = $this->getReportData($period, $group, $month, $year);
        
        // Generate filename
        $monthName = Carbon::createFromDate($year, $month, 1)->format('F');
        $filename = "Laporan_Kilometer_Global_";
        $filename .= "Periode_{$period}_";
        if ($group != 'all') {
            $filename .= "Rute_{$group}_";
        }
        $filename .= "{$monthName}_{$year}.xlsx";
        
        // Return Excel download
        return Excel::download(new class($data) implements FromView, WithTitle, WithStyles {
            private $data;
            
            public function __construct($data)
            {
                $this->data = $data;
            }
            
            public function view(): View
            {
                return view('modules.admin.global-kilometer-reports.exports.excel', $this->data);
            }
            
            public function title(): string
            {
                return $this->data['title'];
            }
            
            public function styles(Worksheet $sheet)
            {
                // Apply styles to the worksheet
                $lastColumn = Coordinate::stringFromColumnIndex(count($this->data['dates']) + 2);
                $lastRow = $sheet->getHighestRow();
                
                // Set column widths
                $sheet->getColumnDimension('A')->setWidth(20);
                for ($i = 2; $i <= count($this->data['dates']) + 1; $i++) {
                    $column = Coordinate::stringFromColumnIndex($i);
                    $sheet->getColumnDimension($column)->setWidth(8);
                }
                $sheet->getColumnDimension($lastColumn)->setWidth(10);
                
                // Style header row
                $sheet->getStyle('A1:' . $lastColumn . '1')->applyFromArray([
                    'font' => [
                        'bold' => true,
                    ],
                    'fill' => [
                        'fillType' => \PhpOffice\PhpSpreadsheet\Style\Fill::FILL_SOLID,
                        'startColor' => [
                            'rgb' => 'E0E0E0',
                        ],
                    ],
                    'borders' => [
                        'allBorders' => [
                            'borderStyle' => \PhpOffice\PhpSpreadsheet\Style\Border::BORDER_THIN,
                        ],
                    ],
                ]);
                
                // Add borders to all cells
                $sheet->getStyle('A1:' . $lastColumn . $lastRow)->applyFromArray([
                    'borders' => [
                        'allBorders' => [
                            'borderStyle' => \PhpOffice\PhpSpreadsheet\Style\Border::BORDER_THIN,
                        ],
                    ],
                ]);
                
                // Style route headers
                foreach ($this->data['routes'] as $routeIndex => $route) {
                    $rowIndex = $routeIndex * 4 + 2; // Adjust based on your template structure
                    $sheet->getStyle('A' . $rowIndex . ':' . $lastColumn . $rowIndex)->applyFromArray([
                        'fill' => [
                            'fillType' => \PhpOffice\PhpSpreadsheet\Style\Fill::FILL_SOLID,
                            'startColor' => [
                                'rgb' => 'F0F0F0',
                            ],
                        ],
                        'font' => [
                            'bold' => true,
                        ],
                    ]);
                }
                
                // Style total row
                $sheet->getStyle('A' . $lastRow . ':' . $lastColumn . $lastRow)->applyFromArray([
                    'font' => [
                        'bold' => true,
                    ],
                    'fill' => [
                        'fillType' => \PhpOffice\PhpSpreadsheet\Style\Fill::FILL_SOLID,
                        'startColor' => [
                            'rgb' => 'E0E0E0',
                        ],
                    ],
                ]);
            }
        }, $filename);
    }
    
    /**
     * Export global kilometer reports to PDF.
     *
     * @param Request $request
     * @return BinaryFileResponse
     */
    public function exportPdf(Request $request)
    {
        $period = $request->input('period', 1);
        $group = $request->input('group', 'all');
        $month = $request->input('month', Carbon::now()->month);
        $year = $request->input('year', Carbon::now()->year);
        
        // Use existing Blade templates for export
        
        // Get report data
        $data = $this->getReportData($period, $group, $month, $year);
        
        // Generate filename
        $monthName = Carbon::createFromDate($year, $month, 1)->format('F');
        $filename = "Laporan_Kilometer_Global_";
        $filename .= "Periode_{$period}_";
        if ($group != 'all') {
            $filename .= "Rute_{$group}_";
        }
        $filename .= "{$monthName}_{$year}.pdf";
        
        // Generate PDF
        $pdf = PDF::loadView('modules.admin.global-kilometer-reports.exports.pdf', $data);
        $pdf->setPaper('a4', 'landscape');
        
        // Return PDF download
        return $pdf->download($filename);
    }
    
    /**
     * Get report data for exports.
     *
     * @param int $period
     * @param string $group
     * @param int $month
     * @param int $year
     * @return array
     */
    private function getReportData($period, $group, $month, $year)
    {
        $currentMonth = Carbon::createFromDate($year, $month, 1);
        
        if ($period == 1) {
            $startDate = $currentMonth->copy()->format('Y-m-d');
            $endDate = $currentMonth->copy()->addDays(14)->format('Y-m-d');
        } else {
            $startDate = $currentMonth->copy()->addDays(15)->format('Y-m-d');
            $endDate = $currentMonth->copy()->endOfMonth()->format('Y-m-d');
        }
        
        if ($group !== 'all') {
            $routes = Route::where('route_number', $group)
                ->with('units')
                ->orderBy('route_number')
                ->get();
        } else {
            $routes = Route::with('units')
                ->orderBy('route_number')
                ->get();
        }
        
        $dates = [];
        $currentDate = Carbon::parse($startDate);
        $lastDate = Carbon::parse($endDate);
        
        while ($currentDate->lte($lastDate)) {
            $dates[] = $currentDate->format('Y-m-d');
            $currentDate->addDay();
        }
        
        $drivers = Driver::active()->get()->keyBy('id');
        $units = Unit::with('drivers')->get()->keyBy('id');
        
        $holidays = Holiday::whereDate('date', '>=', $startDate)
            ->whereDate('date', '<=', $endDate)
            ->get()
            ->keyBy(function ($holiday) {
                return $holiday->date->format('Y-m-d');
            });
            
        $routeTotals = [];
        $unitTotals = [];
        $driverTotals = [];
        $dateTotals = [];
        $routeUnitTotals = [];
        $routeDriverTotals = [];
        
        $reportsByRouteUnitDriverDate = [];
        $driverCountByRouteUnitDate = [];
        $maintenanceUnitsByDate = [];
        $grandTotal = 0;
        
        $hasReports = GlobalKilometerReport::where('period', $period)
            ->where('month', $month)
            ->where('year', $year)
            ->exists();
            
        if ($hasReports) {
            $globalReports = GlobalKilometerReport::with(['driver', 'unit', 'route'])
                ->where('period', $period)
                ->where('month', $month)
                ->where('year', $year);
                
            if ($group !== 'all') {
                $globalReports->whereHas('route', function ($query) use ($group) {
                    $query->where('route_number', $group);
                });
            }
            
            $globalReports = $globalReports->get();
            
            foreach ($globalReports as $report) {
                $unitId = $report->unit_id;
                $routeId = $report->route_id;
                $driverId = $report->driver_id;
                $date = $report->date->format('Y-m-d');
                
                // Initialize arrays if not set
                if (!isset($reportsByRouteUnitDriverDate[$routeId])) {
                    $reportsByRouteUnitDriverDate[$routeId] = [];
                }
                
                if (!isset($reportsByRouteUnitDriverDate[$routeId][$unitId])) {
                    $reportsByRouteUnitDriverDate[$routeId][$unitId] = [];
                }
                
                if (!isset($reportsByRouteUnitDriverDate[$routeId][$unitId][$driverId])) {
                    $reportsByRouteUnitDriverDate[$routeId][$unitId][$driverId] = [];
                }
                
                $reportsByRouteUnitDriverDate[$routeId][$unitId][$driverId][$date] = $report;
                
                // Calculate totals
                if (!isset($routeTotals[$routeId])) {
                    $routeTotals[$routeId] = 0;
                }
                $routeTotals[$routeId] += $report->original_kilometers;
                
                if (!isset($dateTotals[$date])) {
                    $dateTotals[$date] = 0;
                }
                $dateTotals[$date] += $report->original_kilometers;
                
                if (!isset($routeUnitTotals[$routeId][$unitId])) {
                    $routeUnitTotals[$routeId][$unitId] = 0;
                }
                $routeUnitTotals[$routeId][$unitId] += $report->original_kilometers;
                
                if (!isset($routeDriverTotals[$routeId][$driverId])) {
                    $routeDriverTotals[$routeId][$driverId] = 0;
                }
                $routeDriverTotals[$routeId][$driverId] += $report->original_kilometers;
                
                $grandTotal += $report->original_kilometers;
            }
        }
        
        $title = "Laporan Kilometer Global - ";
        $title .= "Periode " . ($period == 1 ? "1 (1-15)" : "2 (16-" . Carbon::createFromDate($year, $month, 1)->endOfMonth()->format('d') . ")");
        $title .= " " . Carbon::createFromDate($year, $month, 1)->format('F Y');
        if ($group !== 'all') {
            $title .= " - Rute " . $group;
        }
        
        return [
            'period' => $period,
            'month' => $month,
            'year' => $year,
            'group' => $group,
            'routes' => $routes,
            'dates' => $dates,
            'drivers' => $drivers,
            'units' => $units,
            'reportsByRouteUnitDriverDate' => $reportsByRouteUnitDriverDate,
            'holidays' => $holidays,
            'routeTotals' => $routeTotals,
            'dateTotals' => $dateTotals,
            'routeUnitTotals' => $routeUnitTotals,
            'routeDriverTotals' => $routeDriverTotals,
            'grandTotal' => $grandTotal,
            'title' => $title
        ];
    }
    
    /**
     * Reset all global kilometer reports data by truncating the table.
     * 
     * @return \Illuminate\Http\RedirectResponse
     */
    public function reset()
    {
        try {
            // Truncate the global_kilometer_reports table
            DB::statement('SET FOREIGN_KEY_CHECKS=0;');
            GlobalKilometerReport::truncate();
            DB::statement('SET FOREIGN_KEY_CHECKS=1;');
            
            return redirect()->route('global-kilometer-reports.index')
                ->with('success', 'Data laporan kilometer global berhasil direset.');
        } catch (\Exception $e) {
            return redirect()->route('global-kilometer-reports.index')
                ->with('error', 'Gagal mereset data: ' . $e->getMessage());
        }
    }
}
