<?php

namespace App\Services;

use App\Models\Driver;
use App\Models\DriverScheduleSettings;
use App\Models\Holiday;
use App\Models\Route;
use App\Models\Schedule;
use App\Models\Unit;
use Carbon\Carbon;
use Carbon\CarbonPeriod;
use Illuminate\Support\Collection;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Log;

class ScheduleGeneratorService
{
    /**
     * Generate schedules for a date range
     * 
     * @param string $startDate
     * @param string $endDate
     * @return array
     */
    public function generateSchedules(string $startDate, string $endDate): array
    {
        // Convert to Carbon instances
        $startDate = Carbon::parse($startDate);
        $endDate = Carbon::parse($endDate);
        
        // Calculate period and validate it's within 15 days (one driver schedule period)
        $days = $startDate->diffInDays($endDate) + 1;
        if ($days > 15) {
            return [
                'success' => false,
                'message' => 'Schedule generation is limited to 15 days per run',
            ];
        }

        // First clean any existing schedules in the range to avoid duplicates
        $this->cleanExistingSchedules($startDate, $endDate);
        
        // Get active units, routes and drivers
        $units = Unit::where('status', 'aktif')->get();
        $routes = Route::where('status', 'aktif')->get();
        $batanganDrivers = Driver::batangan()->active()->get();
        $cadanganDrivers = Driver::cadangan()->active()->get();
        
        // Get driver schedule settings
        $batanganSettings = DriverScheduleSettings::getSettingsForType('batangan');
        $cadanganSettings = DriverScheduleSettings::getSettingsForType('cadangan');
        
        // Get holidays for special handling
        $holidays = $this->getHolidays($startDate, $endDate);
        
        // Create distribution trackers for fair allocation
        $driverScheduleCount = $this->initializeDriverScheduleCounts($batanganDrivers, $cadanganDrivers);
        
        // Generate the schedules
        $results = $this->processScheduleGeneration(
            $startDate, 
            $endDate, 
            $units, 
            $routes, 
            $batanganDrivers, 
            $cadanganDrivers,
            $batanganSettings,
            $cadanganSettings,
            $holidays,
            $driverScheduleCount
        );
        
        return [
            'success' => true,
            'message' => 'Successfully generated schedules',
            'data' => [
                'created' => $results['created'],
                'skipped' => $results['skipped'],
            ],
        ];
    }
    
    /**
     * Remove existing schedules in the date range before creating new ones
     * 
     * @param Carbon $startDate
     * @param Carbon $endDate
     * @return void
     */
    private function cleanExistingSchedules(Carbon $startDate, Carbon $endDate): void
    {
        Schedule::whereBetween('schedule_date', [
            $startDate->format('Y-m-d'),
            $endDate->format('Y-m-d')
        ])->delete();
    }
    
    /**
     * Get holidays in the date range
     * 
     * @param Carbon $startDate
     * @param Carbon $endDate
     * @return Collection
     */
    private function getHolidays(Carbon $startDate, Carbon $endDate): Collection
    {
        return Holiday::whereBetween('date', [
            $startDate->format('Y-m-d'),
            $endDate->format('Y-m-d')
        ])->get();
    }
    
    /**
     * Initialize driver schedule count tracking
     * 
     * @param Collection $batanganDrivers
     * @param Collection $cadanganDrivers
     * @return array
     */
    private function initializeDriverScheduleCounts(Collection $batanganDrivers, Collection $cadanganDrivers): array
    {
        $counts = [];
        foreach ($batanganDrivers as $driver) {
            $counts[$driver->id] = [
                'driver' => $driver,
                'count' => 0,
                'type' => 'batangan',
                'last_schedule' => null,
                'last_shift' => null,
            ];
        }
        
        foreach ($cadanganDrivers as $driver) {
            $counts[$driver->id] = [
                'driver' => $driver,
                'count' => 0,
                'type' => 'cadangan',
                'last_schedule' => null,
                'last_shift' => null,
            ];
        }
        
        return $counts;
    }
    
    /**
     * Process the schedule generation for the date range
     * 
     * @param Carbon $startDate
     * @param Carbon $endDate
     * @param Collection $units
     * @param Collection $routes
     * @param Collection $batanganDrivers
     * @param Collection $cadanganDrivers
     * @param DriverScheduleSettings $batanganSettings
     * @param DriverScheduleSettings $cadanganSettings
     * @param Collection $holidays
     * @param array $driverScheduleCount
     * @return array
     */
    private function processScheduleGeneration(
        Carbon $startDate,
        Carbon $endDate,
        Collection $units,
        Collection $routes,
        Collection $batanganDrivers,
        Collection $cadanganDrivers,
        DriverScheduleSettings $batanganSettings,
        DriverScheduleSettings $cadanganSettings,
        Collection $holidays,
        array $driverScheduleCount
    ): array {
        $created = 0;
        $skipped = 0;
        
        // Define shifts
        $shifts = ['pagi', 'siang'];
        
        // Create a period to iterate through each day
        $period = CarbonPeriod::create($startDate, $endDate);
        
        foreach ($period as $date) {
            $isHoliday = $holidays->contains('date', $date->format('Y-m-d'));
            $isWeekend = $date->isWeekend();
            
            // For each unit and route combination
            foreach ($units as $unit) {
                foreach ($routes as $route) {
                    // Make sure the unit is compatible with the route
                    if (!$this->isUnitCompatibleWithRoute($unit, $route)) {
                        continue;
                    }
                    
                    foreach ($shifts as $shift) {
                        // Select a driver based on fair distribution and availability
                        $driverInfo = $this->selectDriver(
                            $date,
                            $shift,
                            $batanganDrivers,
                            $cadanganDrivers,
                            $batanganSettings,
                            $cadanganSettings,
                            $driverScheduleCount,
                            $isHoliday,
                            $isWeekend,
                            $unit
                        );
                            
                        if (!$driverInfo) {
                            $skipped++;
                            continue;
                        }
                        
                        // Create the schedule
                        $schedule = Schedule::create([
                            'driver_id' => $driverInfo['driver']->id,
                            'route_id' => $route->id,
                            'unit_id' => $unit->id,
                            'schedule_date' => $date->format('Y-m-d'),
                            'shift' => $shift,
                            'status' => 'active',
                        ]);
                        
                        // Update the driver's schedule count
                        $driverScheduleCount[$driverInfo['driver']->id]['count']++;
                        $driverScheduleCount[$driverInfo['driver']->id]['last_schedule'] = $date->format('Y-m-d');
                        $driverScheduleCount[$driverInfo['driver']->id]['last_shift'] = $shift;
                        
                        $created++;
                    }
                }
            }
        }
        
        return [
            'created' => $created,
            'skipped' => $skipped,
        ];
    }
    
    /**
     * Check if a unit is compatible with a route
     * 
     * @param Unit $unit
     * @param Route $route
     * @return bool
     */
    private function isUnitCompatibleWithRoute(Unit $unit, Route $route): bool
    {
        // This is a placeholder, implement according to your application's business logic
        // For example, if there's a relationship between units and routes:
        // return $unit->routes->contains($route->id);
        
        // For now, return true to allow any combination
        return true;
    }
    
    /**
     * Select the most appropriate driver for a schedule
     * 
     * @param Carbon $date
     * @param string $shift
     * @param Collection $batanganDrivers
     * @param Collection $cadanganDrivers
     * @param DriverScheduleSettings $batanganSettings
     * @param DriverScheduleSettings $cadanganSettings
     * @param array $driverScheduleCount
     * @param bool $isHoliday
     * @param bool $isWeekend
     * @param Unit $unit
     * @return array|null
     */
    private function selectDriver(
        Carbon $date,
        string $shift,
        Collection $batanganDrivers,
        Collection $cadanganDrivers,
        DriverScheduleSettings $batanganSettings,
        DriverScheduleSettings $cadanganSettings,
        array $driverScheduleCount,
        bool $isHoliday,
        bool $isWeekend,
        Unit $unit
    ): ?array {
        // Calculate ratio to ensure fair distribution between batangan and cadangan
        // Even if cadangan drivers are fewer than batangan drivers
        $batanganCount = $batanganDrivers->count();
        $cadanganCount = $cadanganDrivers->count();
        
        $totalDrivers = $batanganCount + $cadanganCount;
        $batanganRatio = $totalDrivers > 0 ? $batanganCount / $totalDrivers : 0.5; // Default to 0.5 (50%) if no drivers
        
        // Prioritize batangan drivers for weekdays and cadangan drivers for weekends/holidays
        // But ensure we're respecting the min/max limits for each driver type
        if (($isWeekend || $isHoliday) && $cadanganCount > 0) {
            // Try cadangan drivers first for weekends/holidays
            $selectedDriver = $this->findAvailableDriver(
                $date,
                $shift,
                $cadanganDrivers,
                $driverScheduleCount,
                $cadanganSettings,
                $unit
            );
            
            if (!$selectedDriver && $batanganCount > 0) {
                // Fallback to batangan if no cadangan driver is available
                $selectedDriver = $this->findAvailableDriver(
                    $date,
                    $shift,
                    $batanganDrivers,
                    $driverScheduleCount,
                    $batanganSettings,
                    $unit
                );
            }
        } else {
            // For regular days, distribute based on calculated ratio
            // but prioritize batangan drivers
            $batanganTotalSchedules = $this->getTotalSchedulesForType($driverScheduleCount, 'batangan');
            $cadanganTotalSchedules = $this->getTotalSchedulesForType($driverScheduleCount, 'cadangan');
            
            $totalSchedules = $batanganTotalSchedules + $cadanganTotalSchedules;
            $currentBatanganRatio = ($batanganCount > 0 && $totalSchedules > 0) ? 
                $batanganTotalSchedules / $totalSchedules : 0;
            
            // If batangan ratio is too low, prioritize batangan drivers
            if ($batanganCount > 0 && ($currentBatanganRatio < $batanganRatio || $cadanganCount === 0)) {
                $selectedDriver = $this->findAvailableDriver(
                    $date,
                    $shift,
                    $batanganDrivers,
                    $driverScheduleCount,
                    $batanganSettings,
                    $unit
                );
                
                if (!$selectedDriver && $cadanganCount > 0) {
                    $selectedDriver = $this->findAvailableDriver(
                        $date,
                        $shift,
                        $cadanganDrivers,
                        $driverScheduleCount,
                        $cadanganSettings,
                        $unit
                    );
                }
            } else if ($cadanganCount > 0) {
                // If we have enough batangan assignment, prioritize cadangan
                $selectedDriver = $this->findAvailableDriver(
                    $date,
                    $shift,
                    $cadanganDrivers,
                    $driverScheduleCount,
                    $cadanganSettings,
                    $unit
                );
                
                if (!$selectedDriver && $batanganCount > 0) {
                    $selectedDriver = $this->findAvailableDriver(
                        $date,
                        $shift,
                        $batanganDrivers,
                        $driverScheduleCount,
                        $batanganSettings,
                        $unit
                    );
                }
            } else {
                $selectedDriver = null;
            }
        }
        
        return $selectedDriver;
    }
    
    /**
     * Find an available driver from the provided collection
     * 
     * @param Carbon $date
     * @param string $shift
     * @param Collection $drivers
     * @param array $driverScheduleCount
     * @param DriverScheduleSettings $settings
     * @param Unit $unit
     * @return array|null
     */
    private function findAvailableDriver(
        Carbon $date,
        string $shift,
        Collection $drivers,
        array $driverScheduleCount,
        DriverScheduleSettings $settings,
        Unit $unit
    ): ?array {
        // Filter drivers who are qualified for this unit
        $qualifiedDrivers = $drivers->filter(function ($driver) use ($unit) {
            return $driver->units->contains($unit->id);
        });
        
        if ($qualifiedDrivers->isEmpty()) {
            return null;
        }
        
        // Sort drivers by their current schedule count (ascending)
        // to prioritize drivers with fewer schedules
        $sortedDrivers = $qualifiedDrivers->sortBy(function ($driver) use ($driverScheduleCount) {
            return $driverScheduleCount[$driver->id]['count'];
        });
        
        foreach ($sortedDrivers as $driver) {
            // Skip if driver already reached max schedules
            if ($driverScheduleCount[$driver->id]['count'] >= $settings->max_schedules) {
                continue;
            }
            
            // Check if driver is available for this date and shift
            if ($driver->isAvailableFor($date->format('Y-m-d'), $shift)) {
                // Special check for shift sequence
                if ($shift === 'pagi') {
                    $previousDay = $date->copy()->subDay();
                    $previousDayId = $previousDay->format('Y-m-d');
                    
                    $lastSchedule = $driverScheduleCount[$driver->id]['last_schedule'];
                    $lastShift = $driverScheduleCount[$driver->id]['last_shift'];
                    
                    // If the driver had an evening shift the previous day, they cannot have a morning shift
                    if ($lastSchedule === $previousDayId && $lastShift === 'siang') {
                        continue;
                    }
                }
                
                return [
                    'driver' => $driver,
                    'count' => $driverScheduleCount[$driver->id]['count'],
                ];
            }
        }
        
        return null;
    }
    
    /**
     * Get the total scheduled count for a driver type
     * 
     * @param array $driverScheduleCount
     * @param string $type
     * @return int
     */
    private function getTotalSchedulesForType(array $driverScheduleCount, string $type): int
    {
        $total = 0;
        
        foreach ($driverScheduleCount as $driverId => $info) {
            if ($info['type'] === $type) {
                $total += $info['count'];
            }
        }
        
        return $total;
    }
}
