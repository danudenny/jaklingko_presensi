<?php

namespace App\Services;

use App\Models\Driver;
use App\Models\Unit;
use App\Models\Schedule;
use App\Models\DriverHistory;
use App\Models\DriverScheduleHistory;
use Carbon\Carbon;
use Illuminate\Support\Collection;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Log;

class SchedulePlannerService
{
    private $driverSelectionService;
    private $utilityService;

    public function __construct(
        DriverSelectionService $driverSelectionService,
        ScheduleGeneratorUtilityService $utilityService
    ) {
        $this->driverSelectionService = $driverSelectionService;
        $this->utilityService = $utilityService;
    }

    public function generateSchedulePlan(
        string $startDate,
        string $endDate,
        Collection $units,
        Collection $batanganDrivers,
        Collection $cadanganDrivers,
        array $batanganSettings,
        array $cadanganSettings, 
        array $unavailableDays
    ): array {
        Log::info("Starting generateSchedulePlan", [
            'startDate' => $startDate,
            'endDate' => $endDate,
            'unitsCount' => $units->count(),
            'batanganDriversCount' => $batanganDrivers->count(),
            'cadanganDriversCount' => $cadanganDrivers->count(),
            'batanganSettings' => $batanganSettings,
            'cadanganSettings' => $cadanganSettings,
            'unavailableDays' => count($unavailableDays)
        ]);

        if ($units->isEmpty()) {
            Log::error("No units provided for schedule generation");
            return [];
        }

        if ($batanganDrivers->isEmpty() && $cadanganDrivers->isEmpty()) {
            Log::error("No drivers provided for schedule generation");
            return [];
        }

        $start = Carbon::parse($startDate);
        $end = Carbon::parse($endDate);

        $schedulePlan = [];
        $driverScheduleCounts = [];
        $lastShiftByDriver = [];
        $unitAssignments = [];
        $routeAssignments = [];
        $dailyDriverAssignments = []; // Track which drivers are assigned on each day
        $driverShiftHistory = []; // Track shift history for each driver with dates
        
        foreach ($units as $unit) {
            if (!isset($unitAssignments[$unit->id])) {
                $unitAssignments[$unit->id] = [];
            }
            
            $batanganCount = 0;
            $batanganDrivers->each(function($driver) use ($unit, &$unitAssignments, &$batanganCount) {
                if ($driver->units->contains('id', $unit->id)) {
                    $unitAssignments[$unit->id][$driver->id] = 'batangan';
                    $batanganCount++;
                }
            });
            
            $cadanganCount = 0;
            $cadanganDrivers->each(function($driver) use ($unit, &$unitAssignments, &$cadanganCount) {
                if ($driver->units->contains('id', $unit->id)) {
                    $unitAssignments[$unit->id][$driver->id] = 'cadangan';
                    $cadanganCount++;
                }
            });
            
            Log::info("Unit {$unit->id} assigned drivers: $batanganCount batangan, $cadanganCount cadangan");
            
            if ($unit->routes->isNotEmpty()) {
                $routeId = $unit->routes->first()->id;
                if (!isset($routeAssignments[$routeId])) {
                    $routeAssignments[$routeId] = [];
                }
                foreach ($unitAssignments[$unit->id] as $driverId => $type) {
                    $routeAssignments[$routeId][$driverId] = $type;
                }
            }
        }
        
        foreach ($batanganDrivers as $driver) {
            $driverScheduleCounts[$driver->id] = [
                'type' => 'batangan',
                'total' => 0,
                'morning' => 0,
                'afternoon' => 0
            ];
            $lastShiftByDriver[$driver->id] = null;
            $driverShiftHistory[$driver->id] = []; // Initialize shift history
        }
        
        foreach ($cadanganDrivers as $driver) {
            $driverScheduleCounts[$driver->id] = [
                'type' => 'cadangan',
                'total' => 0,
                'morning' => 0,
                'afternoon' => 0
            ];
            $lastShiftByDriver[$driver->id] = null;
            $driverShiftHistory[$driver->id] = []; // Initialize shift history
        }

        $current = $start->copy();
        while ($current <= $end) {
            $dateStr = $current->format('Y-m-d');
            Log::info("Processing date: $dateStr");
            
            $schedulePlan[$dateStr] = [];
            $dailyDriverAssignments[$dateStr] = []; // Initialize empty array for tracking drivers on this day
            
            // Log the current day's assignments for debugging
            Log::info("Starting assignments for date: $dateStr", [
                'dailyDriverAssignments' => $dailyDriverAssignments[$dateStr] ?? []
            ]);
            
            foreach ($units as $unit) {
                if (isset($unavailableDays[$dateStr]) && in_array($unit->id, $unavailableDays[$dateStr])) {
                    Log::info("Unit {$unit->id} is unavailable on $dateStr");
                    continue;
                }

                if (!isset($unitAssignments[$unit->id]) || empty($unitAssignments[$unit->id])) {
                    Log::warning("No drivers assigned to unit {$unit->id}");
                    continue;
                }

                Log::info("Processing unit {$unit->id} for date $dateStr", [
                    'availableDrivers' => $unitAssignments[$unit->id]
                ]);

                $schedulePlan[$dateStr][$unit->id] = [
                    'morning' => [],
                    'afternoon' => []
                ];
                
                $assignedMorning = false;
                if (isset($unitAssignments[$unit->id])) {
                    $batanganOption = $this->findBestDriver(
                        $unitAssignments[$unit->id],
                        'batangan',
                        'pagi',
                        $driverScheduleCounts,
                        $lastShiftByDriver,
                        $batanganSettings,
                        $dailyDriverAssignments,
                        $dateStr,
                        $driverShiftHistory
                    );
                    
                    Log::info("Batangan morning option for unit {$unit->id}", [
                        'date' => $dateStr,
                        'result' => $batanganOption,
                        'availableDrivers' => array_filter($unitAssignments[$unit->id], fn($type) => $type === 'batangan')
                    ]);
                    
                    if ($batanganOption) {
                        $schedulePlan[$dateStr][$unit->id]['morning'] = [
                            'type' => 'batangan',
                            'driver_id' => $batanganOption
                        ];
                        $driverScheduleCounts[$batanganOption]['total']++;
                        $driverScheduleCounts[$batanganOption]['morning']++;
                        $lastShiftByDriver[$batanganOption] = 'pagi';
                        $assignedMorning = true;
                        $dailyDriverAssignments[$dateStr][$batanganOption] = true; // Mark this driver as assigned for this day
                        
                        // Record shift history
                        $driverShiftHistory[$batanganOption][] = [
                            'date' => $dateStr,
                            'shift' => 'pagi',
                            'unit_id' => $unit->id
                        ];
                    }
                    
                    if (!$assignedMorning) {
                        $cadanganOption = $this->findBestDriver(
                            $unitAssignments[$unit->id],
                            'cadangan',
                            'pagi',
                            $driverScheduleCounts,
                            $lastShiftByDriver,
                            $cadanganSettings,
                            $dailyDriverAssignments,
                            $dateStr,
                            $driverShiftHistory
                        );
                        
                        if ($cadanganOption) {
                            $schedulePlan[$dateStr][$unit->id]['morning'] = [
                                'type' => 'cadangan',
                                'driver_id' => $cadanganOption
                            ];
                            $driverScheduleCounts[$cadanganOption]['total']++;
                            $driverScheduleCounts[$cadanganOption]['morning']++;
                            $lastShiftByDriver[$cadanganOption] = 'pagi';
                            $assignedMorning = true;
                            $dailyDriverAssignments[$dateStr][$cadanganOption] = true; // Mark this driver as assigned for this day
                            
                            // Record shift history
                            $driverShiftHistory[$cadanganOption][] = [
                                'date' => $dateStr,
                                'shift' => 'pagi',
                                'unit_id' => $unit->id
                            ];
                        }
                    }
                }
                
                $assignedAfternoon = false;
                if (isset($unitAssignments[$unit->id])) {
                    // Before finding afternoon drivers, log the current day's assignments for debugging
                    Log::info("Before afternoon shift assignment for unit {$unit->id} on $dateStr", [
                        'dailyDriverAssignments' => $dailyDriverAssignments[$dateStr] ?? []
                    ]);
                    $batanganOption = $this->findBestDriver(
                        $unitAssignments[$unit->id],
                        'batangan',
                        'siang',
                        $driverScheduleCounts,
                        $lastShiftByDriver,
                        $batanganSettings,
                        $dailyDriverAssignments,
                        $dateStr,
                        $driverShiftHistory
                    );
                    
                    if ($batanganOption) {
                        $schedulePlan[$dateStr][$unit->id]['afternoon'] = [
                            'type' => 'batangan',
                            'driver_id' => $batanganOption
                        ];
                        $driverScheduleCounts[$batanganOption]['total']++;
                        $driverScheduleCounts[$batanganOption]['afternoon']++;
                        $lastShiftByDriver[$batanganOption] = 'siang';
                        $assignedAfternoon = true;
                        $dailyDriverAssignments[$dateStr][$batanganOption] = true; // Mark this driver as assigned for this day
                        
                        // Record shift history
                        $driverShiftHistory[$batanganOption][] = [
                            'date' => $dateStr,
                            'shift' => 'siang',
                            'unit_id' => $unit->id
                        ];
                    }
                    
                    if (!$assignedAfternoon) {
                        $cadanganOption = $this->findBestDriver(
                            $unitAssignments[$unit->id],
                            'cadangan',
                            'siang',
                            $driverScheduleCounts,
                            $lastShiftByDriver,
                            $cadanganSettings,
                            $dailyDriverAssignments,
                            $dateStr,
                            $driverShiftHistory
                        );
                        
                        if ($cadanganOption) {
                            $schedulePlan[$dateStr][$unit->id]['afternoon'] = [
                                'type' => 'cadangan',
                                'driver_id' => $cadanganOption
                            ];
                            $driverScheduleCounts[$cadanganOption]['total']++;
                            $driverScheduleCounts[$cadanganOption]['afternoon']++;
                            $lastShiftByDriver[$cadanganOption] = 'siang';
                            $assignedAfternoon = true;
                            $dailyDriverAssignments[$dateStr][$cadanganOption] = true; // Mark this driver as assigned for this day
                            
                            // Record shift history
                            $driverShiftHistory[$cadanganOption][] = [
                                'date' => $dateStr,
                                'shift' => 'siang',
                                'unit_id' => $unit->id
                            ];
                        }
                    }
                }
            }
            
            $current->addDay();
        }

        // Final validation to ensure no driver is assigned to multiple shifts on the same day
        $this->validateNoMultipleShiftsPerDay($schedulePlan);
        
        $scheduledShifts = 0;
        foreach ($schedulePlan as $date => $unitPlans) {
            foreach ($unitPlans as $unitId => $shifts) {
                foreach (['pagi', 'siang'] as $shift) {
                    if (!empty($shifts[$shift]) && isset($shifts[$shift]['driver_id'])) {
                        $scheduledShifts++;
                    }
                }
            }
        }
        
        Log::info("Schedule generation completed", [
            'totalShiftsScheduled' => $scheduledShifts,
            'driverCounts' => $driverScheduleCounts
        ]);

        return $schedulePlan;
    }

    public function optimizeSchedulePlan(array $schedulePlan): array
    {
        Log::info("Starting schedule optimization");
        $driverCounts = [];
        $unitShiftCounts = [];
        
        // Verify all unit IDs exist in the database
        $allUnitIds = [];
        foreach ($schedulePlan as $date => $unitPlans) {
            foreach ($unitPlans as $unitId => $shifts) {
                $allUnitIds[$unitId] = true;
            }
        }
        
        $existingUnits = Unit::whereIn('id', array_keys($allUnitIds))->pluck('id')->toArray();
        $validUnitIds = array_flip($existingUnits);
        
        // Filter out invalid units
        foreach ($schedulePlan as $date => $unitPlans) {
            foreach ($unitPlans as $unitId => $shifts) {
                if (!isset($validUnitIds[$unitId])) {
                    Log::warning("Unit ID $unitId not found in database, removing from schedule plan");
                    unset($schedulePlan[$date][$unitId]);
                }
            }
            
            // If no units remain for this date after filtering, remove the date
            if (empty($schedulePlan[$date])) {
                unset($schedulePlan[$date]);
            }
        }

        // First pass: Count driver assignments and unit shifts
        foreach ($schedulePlan as $date => $unitPlans) {
            foreach ($unitPlans as $unitId => $shifts) {
                // Map between database terminology and schedule plan keys
                $shiftMap = [
                    'pagi' => 'morning',
                    'siang' => 'afternoon'
                ];
                
                foreach (['pagi', 'siang'] as $shift) {
                    $planShiftKey = $shiftMap[$shift];
                    
                    if (isset($shifts[$planShiftKey]['driver_id'])) {
                        $driverId = $shifts[$planShiftKey]['driver_id'];
                        $driverType = $shifts[$planShiftKey]['type'];
                        
                        if (!isset($driverCounts[$driverId])) {
                            $driverCounts[$driverId] = [
                                'type' => $driverType,
                                'count' => 0,
                                'units' => []
                            ];
                        }
                        
                        $driverCounts[$driverId]['count']++;
                        if (!in_array($unitId, $driverCounts[$driverId]['units'])) {
                            $driverCounts[$driverId]['units'][] = $unitId;
                        }
                    }
                }

                // Track shifts per unit per day
                if (!isset($unitShiftCounts[$date][$unitId])) {
                    $unitShiftCounts[$date][$unitId] = 0;
                }
                $unitShiftCounts[$date][$unitId] += isset($shifts['morning']['driver_id']) ? 1 : 0;
                $unitShiftCounts[$date][$unitId] += isset($shifts['afternoon']['driver_id']) ? 1 : 0;
            }
        }

        // Second pass: Apply optimizations
        foreach ($schedulePlan as $date => $unitPlans) {
            foreach ($unitPlans as $unitId => $shifts) {
                // Ensure each unit has both shifts if possible
                if (!isset($unitShiftCounts[$date][$unitId]) || $unitShiftCounts[$date][$unitId] !== 2) {
                    // Map between shifts in plan vs database terminology
                    $shiftMap = [
                        'pagi' => 'morning',
                        'siang' => 'afternoon'
                    ];
                    
                    foreach (['pagi', 'siang'] as $shift) {
                        $planShiftKey = $shiftMap[$shift];
                        
                        if (!isset($shifts[$planShiftKey]['driver_id'])) {
                            // Find available driver who:
                            // 1. Is not already assigned that day
                            // 2. Has not reached their schedule limit
                            // 3. Is qualified for the unit
                            // 4. Would maintain shift balance
                            $availableDriver = $this->findAvailableDriverForShift(
                                $unitId,
                                $date,
                                $shift,
                                $schedulePlan,
                                $driverCounts
                            );
                            
                            if ($availableDriver) {
                                $schedulePlan[$date][$unitId][$planShiftKey] = [
                                    'driver_id' => $availableDriver['id'],
                                    'type' => $availableDriver['type']
                                ];
                                $driverCounts[$availableDriver['id']]['count']++;
                                $unitShiftCounts[$date][$unitId]++;
                                Log::info("Assigned driver {$availableDriver['id']} to unit $unitId on $date shift $planShiftKey");
                            }
                        }
                    }
                }

                // Check driver limits and redistribute if needed
                $shiftMap = [
                    'pagi' => 'morning',
                    'siang' => 'afternoon'
                ];
                
                foreach (['pagi', 'siang'] as $shift) {
                    $planShiftKey = $shiftMap[$shift];
                    
                    if (isset($shifts[$planShiftKey]['driver_id'])) {
                        $driverId = $shifts[$planShiftKey]['driver_id'];
                        $driverType = $shifts[$planShiftKey]['type'];
                        
                        if ($driverType === 'batangan' && $driverCounts[$driverId]['count'] > 14) {
                            // Find another batangan driver who:
                            // 1. Has fewer than 14 shifts
                            // 2. Is qualified for this unit
                            // 3. Is not already assigned that day
                            $replacement = $this->findReplacementDriver(
                                $unitId,
                                $date,
                                $shift,
                                'batangan',
                                $schedulePlan,
                                $driverCounts
                            );
                            
                            if ($replacement) {
                                $schedulePlan[$date][$unitId][$planShiftKey]['driver_id'] = $replacement['id'];
                                $driverCounts[$driverId]['count']--;
                                $driverCounts[$replacement['id']]['count']++;
                                Log::info("Replaced driver $driverId with {$replacement['id']} for unit $unitId on $date shift $planShiftKey - batangan");
                            }
                        } elseif ($driverType === 'cadangan' && $driverCounts[$driverId]['count'] > 11) {
                            // Find another cadangan driver who:
                            // 1. Has fewer than 11 shifts
                            // 2. Is qualified for this unit
                            // 3. Is not already assigned that day
                            $replacement = $this->findReplacementDriver(
                                $unitId,
                                $date,
                                $shift,
                                'cadangan',
                                $schedulePlan,
                                $driverCounts
                            );
                            
                            if ($replacement) {
                                $schedulePlan[$date][$unitId][$planShiftKey]['driver_id'] = $replacement['id'];
                                $driverCounts[$driverId]['count']--;
                                $driverCounts[$replacement['id']]['count']++;
                                Log::info("Replaced driver $driverId with {$replacement['id']} for unit $unitId on $date shift $planShiftKey - cadangan");
                            }
                        }
                    }
                }
            }
        }

        return $schedulePlan;
    }

    public function createSchedulesFromPlan(array $schedulePlan): void
    {
        DB::beginTransaction();
        try {
            $count = 0;
            $errors = [];

            // Log what we're working with
            $totalShifts = 0;
            foreach ($schedulePlan as $date => $unitPlans) {
                foreach ($unitPlans as $unitId => $shifts) {
                    foreach (['morning', 'afternoon'] as $shiftKey) {
                        if (!empty($shifts[$shiftKey]) && isset($shifts[$shiftKey]['driver_id'])) {
                            $totalShifts++;
                        }
                    }
                }
            }
            Log::info("Starting createSchedulesFromPlan with $totalShifts total shifts to process");

            foreach ($schedulePlan as $date => $unitPlans) {
                foreach ($unitPlans as $unitId => $shifts) {
                    $unit = Unit::find($unitId);
                    if (!$unit) {
                        Log::error("Unit ID $unitId not found in database");
                        $errors[] = "Unit ID $unitId not found";
                        continue;
                    }
                    
                    if ($unit->routes->isEmpty()) {
                        Log::error("Unit $unitId has no routes assigned");
                        $errors[] = "Unit $unitId has no routes";
                        continue;
                    }

                    $routeId = $unit->routes->first()->id;

                    // Map morning/afternoon to pagi/siang
                    $shiftMap = [
                        'morning' => 'pagi',
                        'afternoon' => 'siang'
                    ];

                    foreach ($shiftMap as $planKey => $dbShift) {
                        if (!empty($shifts[$planKey]) && isset($shifts[$planKey]['driver_id'])) {
                            try {
                                $driverId = $shifts[$planKey]['driver_id'];
                                
                                // Verify the driver exists
                                $driver = Driver::find($driverId);
                                if (!$driver) {
                                    Log::error("Driver ID $driverId not found in database");
                                    $errors[] = "Driver ID $driverId not found";
                                    continue;
                                }

                                Schedule::create([
                                    'unit_id' => $unitId,
                                    'driver_id' => $driverId,
                                    'route_id' => $routeId,
                                    'schedule_date' => $date,
                                    'shift' => $dbShift,
                                    'status' => 'active'
                                ]);
                                
                                $count++;
                                Log::info("Created schedule: unit $unitId, driver $driverId, date $date, shift $dbShift");
                            } catch (\Exception $e) {
                                Log::error("Error creating schedule: " . $e->getMessage(), [
                                    'unit_id' => $unitId,
                                    'driver_id' => $shifts[$planKey]['driver_id'] ?? 'unknown',
                                    'date' => $date,
                                    'shift' => $dbShift
                                ]);
                                $errors[] = "Error with unit $unitId: " . $e->getMessage();
                            }
                        }
                    }
                }
            }
            
            if ($count > 0) {
                DB::commit();
                Log::info("Successfully created $count schedules");
            } else {
                DB::rollBack();
                Log::error("No schedules were created. Rolling back transaction.", ['errors' => $errors]);
                throw new \Exception("Failed to create any schedules: " . implode(", ", $errors));
            }
        } catch (\Exception $e) {
            DB::rollBack();
            Log::error("Error creating schedules: " . $e->getMessage(), ['trace' => $e->getTraceAsString()]);
            throw $e;
        }
    }
    
    private function findBestDriver(
        array $unitDrivers,
        string $type,
        string $shift,
        array $driverScheduleCounts,
        array $lastShiftByDriver,
        array $settings,
        array $dailyDriverAssignments = [],
        string $currentDate = null,
        array $driverShiftHistory = []
    ): ?int {
        Log::info("Finding best $type driver for $shift shift", [
            'availableDrivers' => count($unitDrivers),
            'currentDate' => $currentDate,
            'shift' => $shift
        ]);
        
        if (!$currentDate) {
            Log::warning("No current date provided, cannot apply pattern-based scheduling");
            return null;
        }
        
        $candidates = [];
        $patternCandidates = [];
        $otherCandidates = [];
        
        // Get the day index (1-based) within the period for pattern matching
        $dayIndex = $this->getDayIndexInPeriod($currentDate);
        Log::info("Current day index in period: $dayIndex");
        
        // Define the patterns for each driver type
        $patterns = [
            'batangan' => [
                'pattern1' => ['p', 'p', 's', 'n', 'p'], // Driver 1 pattern
                'pattern2' => ['s', 's', 'n', 'p', 's']  // Driver 2 pattern
            ],
            'cadangan' => [
                'pattern1' => ['n', 'n', 'p', 's', 'n']  // Cadangan pattern
            ]
        ];
        
        // Find drivers who match the pattern requirements
        foreach ($unitDrivers as $driverId => $driverType) {
            if ($driverType !== $type || !isset($driverScheduleCounts[$driverId])) {
                continue;
            }
            
            // Skip if driver is already assigned on this day
            if (isset($dailyDriverAssignments[$currentDate][$driverId])) {
                Log::info("Driver $driverId already assigned on $currentDate, skipping");
                continue;
            }
            
            // Double-check by scanning through the shift history for this date
            $alreadyHasShiftToday = false;
            if (!empty($driverShiftHistory[$driverId])) {
                foreach ($driverShiftHistory[$driverId] as $historyEntry) {
                    if ($historyEntry['date'] === $currentDate) {
                        Log::info("Driver $driverId already has a shift on $currentDate according to shift history, skipping");
                        $alreadyHasShiftToday = true;
                        break;
                    }
                }
            }
            
            if ($alreadyHasShiftToday) {
                continue;
            }
            
            $stats = $driverScheduleCounts[$driverId];
            $maxSchedules = $settings['max_schedules'] ?? ($type === 'batangan' ? 14 : 11);
            
            // Skip if over total limit
            if ($stats['total'] >= $maxSchedules) {
                continue;
            }
            
            // Determine which pattern this driver should follow
            $patternKey = $this->determineDriverPattern($driverId, $type, $driverShiftHistory);
            $pattern = $patterns[$type][$patternKey] ?? [];
            
            // Get the expected shift for this day in the pattern
            $expectedShift = $pattern[$dayIndex - 1] ?? null; // Pattern is 0-indexed, dayIndex is 1-indexed
            
            // Calculate score based on schedule balance
            $score = $this->scoreDriverOption($driverId, $shift, $driverScheduleCounts, $lastShiftByDriver);
            
            // Prioritize drivers with fewer assignments
            $score += (($maxSchedules - $stats['total']) * 10);
            
            // If this driver's expected shift matches the requested shift, prioritize them
            if ($expectedShift === $shift) {
                Log::info("Driver $driverId matches pattern for $shift on day $dayIndex");
                $patternCandidates[$driverId] = $score + 100; // Bonus for matching pattern
            } else if ($expectedShift !== 'n') { // If driver should have a shift but not this one
                Log::info("Driver $driverId should have $expectedShift shift on day $dayIndex, not $shift");
                continue; // Skip this driver as they should have a different shift
            } else {
                // Driver should have no schedule, but we'll keep them as a fallback
                $otherCandidates[$driverId] = $score;
            }
        }
        
        // Use pattern-matching candidates first, then others as fallback
        if (!empty($patternCandidates)) {
            $candidates = $patternCandidates;
        } else if (!empty($otherCandidates)) {
            $candidates = $otherCandidates;
        }
        
        if (empty($candidates)) {
            Log::warning("No suitable candidates found for $type driver on $currentDate for $shift shift");
            return null;
        }
        
        arsort($candidates);
        $selectedDriver = array_key_first($candidates);
        
        Log::info("Selected driver $selectedDriver for $shift shift on $currentDate");
        return $selectedDriver;
    }
    
    /**
     * Determine which pattern a driver should follow
     * 
     * @param int $driverId The driver ID
     * @param string $type The driver type ('batangan', 'cadangan')
     * @param array $driverShiftHistory The shift history for all drivers
     * @return string The pattern key ('pattern1', 'pattern2')
     */
    private function determineDriverPattern(int $driverId, string $type, array $driverShiftHistory): string
    {
        // For cadangan drivers, there's only one pattern
        if ($type === 'cadangan') {
            return 'pattern1';
        }
        
        // For batangan drivers, determine based on history or driver ID
        if (!empty($driverShiftHistory[$driverId])) {
            // Sort by date (ascending)
            $history = $driverShiftHistory[$driverId];
            usort($history, function($a, $b) {
                return strcmp($a['date'], $b['date']);
            });
            
            // Check first shift to determine pattern
            if (!empty($history)) {
                $firstShift = $history[0]['shift'];
                if ($firstShift === 'pagi') {
                    return 'pattern1'; // Driver 1 pattern
                } else if ($firstShift === 'siang') {
                    return 'pattern2'; // Driver 2 pattern
                }
            }
        }
        
        // If no history or no clear pattern, assign based on driver ID
        return ($driverId % 2 === 0) ? 'pattern1' : 'pattern2';
    }
    
    /**
     * Get the day index (1-5) within the current period
     * 
     * @param string $date The date to check
     * @return int The day index (1-5)
     */
    private function getDayIndexInPeriod(string $date): int
    {
        $day = (int)date('d', strtotime($date));
        
        // First period: days 1-15
        if ($day <= 15) {
            return min(5, $day); // Cap at 5 for pattern purposes
        }
        
        // Second period: days 16-end of month
        // Map days 16-20 to pattern days 1-5
        return min(5, $day - 15);
    }
    
    /**
     * Check if a driver follows the required pattern based on their history
     * 
     * @param int $driverId The driver ID
     * @param string $currentDate The current date
     * @param array $driverShiftHistory The shift history for all drivers
     * @param array $pattern The pattern to check against
     * @return bool True if the driver follows the pattern, false otherwise
     */
    private function driverFollowsPattern(int $driverId, string $currentDate, array $driverShiftHistory, array $pattern): bool
    {
        if (empty($driverShiftHistory[$driverId])) {
            // New driver with no history always follows the pattern
            return true;
        }
        
        // Get the previous 4 days to check pattern
        $checkDates = [];
        $currentDayIndex = $this->getDayIndexInPeriod($currentDate);
        
        // We only need to check previous days in the pattern
        for ($i = 1; $i < $currentDayIndex; $i++) {
            $checkDates[$i] = date('Y-m-d', strtotime($currentDate . " -" . ($currentDayIndex - $i) . " days"));
        }
        
        // Check each previous day in the pattern
        foreach ($checkDates as $dayIndex => $date) {
            $expectedShifts = $pattern[$dayIndex];
            $actualShift = $this->getDriverShiftForDate($driverId, $date, $driverShiftHistory);
            
            // If driver had no shift but should have had one according to pattern
            if ($actualShift === null && !in_array('n', $expectedShifts)) {
                Log::info("Driver $driverId should have had a shift on $date (day $dayIndex) but didn't");
                return false;
            }
            
            // If driver had a shift but should not have had one according to pattern
            if ($actualShift !== null && in_array('n', $expectedShifts) && count($expectedShifts) === 1) {
                Log::info("Driver $driverId had a shift on $date (day $dayIndex) but shouldn't have");
                return false;
            }
            
            // If driver had a shift but it's not in the expected shifts for this day
            if ($actualShift !== null && !in_array($actualShift, $expectedShifts)) {
                Log::info("Driver $driverId had shift $actualShift on $date (day $dayIndex) but expected one of: " . implode(',', $expectedShifts));
                return false;
            }
        }
        
        return true;
    }
    
    /**
     * Get a driver's shift for a specific date
     * 
     * @param int $driverId The driver ID
     * @param string $date The date to check
     * @param array $driverShiftHistory The shift history for all drivers
     * @return string|null The shift ('pagi', 'siang') or null if no shift
     */
    private function getDriverShiftForDate(int $driverId, string $date, array $driverShiftHistory): ?string
    {
        if (empty($driverShiftHistory[$driverId])) {
            return null;
        }
        
        foreach ($driverShiftHistory[$driverId] as $historyEntry) {
            if ($historyEntry['date'] === $date) {
                return $historyEntry['shift'];
            }
        }
        
        return null;
    }
    
    /**
     * Determine a driver's current shift pattern based on their history
     * 
     * @param int $driverId The driver ID
     * @param array $driverShiftHistory The shift history for all drivers
     * @return string|null The driver's shift pattern ('pagi', 'siang') or null if no pattern
     */
    private function determineDriverShiftPattern(int $driverId, array $driverShiftHistory): ?string
    {
        if (empty($driverShiftHistory[$driverId])) {
            return null;
        }
        
        $pagiCount = 0;
        $siangCount = 0;
        
        foreach ($driverShiftHistory[$driverId] as $historyEntry) {
            if ($historyEntry['shift'] === 'pagi') {
                $pagiCount++;
            } else if ($historyEntry['shift'] === 'siang') {
                $siangCount++;
            }
        }
        
        // If driver has no shifts yet, return null
        if ($pagiCount === 0 && $siangCount === 0) {
            return null;
        }
        
        // Return the dominant shift pattern
        return ($pagiCount >= $siangCount) ? 'pagi' : 'siang';
    }
    
    /**
     * Validate and fix any cases where a driver is assigned to multiple shifts on the same day
     * 
     * @param array $schedulePlan The generated schedule plan
     * @return void
     */
    private function validateNoMultipleShiftsPerDay(array &$schedulePlan): void
    {
        Log::info("Validating no multiple shifts per day");
        
        foreach ($schedulePlan as $date => $unitPlans) {
            $driverAssignments = [];
            $conflictingAssignments = [];
            
            // First pass: identify all driver assignments for this day
            foreach ($unitPlans as $unitId => $shifts) {
                foreach (['morning', 'afternoon'] as $shiftKey) {
                    if (!empty($shifts[$shiftKey]) && isset($shifts[$shiftKey]['driver_id'])) {
                        $driverId = $shifts[$shiftKey]['driver_id'];
                        
                        if (!isset($driverAssignments[$driverId])) {
                            $driverAssignments[$driverId] = [
                                'units' => [$unitId],
                                'shifts' => [$shiftKey],
                                'types' => [$shifts[$shiftKey]['type']]
                            ];
                        } else {
                            // This driver already has an assignment on this day
                            $driverAssignments[$driverId]['units'][] = $unitId;
                            $driverAssignments[$driverId]['shifts'][] = $shiftKey;
                            $driverAssignments[$driverId]['types'][] = $shifts[$shiftKey]['type'];
                            
                            // Mark as conflicting if this is a different shift or unit
                            if (count(array_unique($driverAssignments[$driverId]['shifts'])) > 1 ||
                                count(array_unique($driverAssignments[$driverId]['units'])) > 1) {
                                $conflictingAssignments[$driverId] = $driverAssignments[$driverId];
                            }
                        }
                    }
                }
            }
            
            // Second pass: fix any conflicts by removing the afternoon shift assignment
            foreach ($conflictingAssignments as $driverId => $assignments) {
                Log::warning("Driver $driverId has multiple shifts on $date", [
                    'assignments' => $assignments
                ]);
                
                // Keep morning shift, remove afternoon shift
                $afternoonUnitIndex = array_search('afternoon', $assignments['shifts']);
                if ($afternoonUnitIndex !== false) {
                    $unitToFix = $assignments['units'][$afternoonUnitIndex];
                    Log::info("Removing afternoon shift for driver $driverId on unit $unitToFix on $date");
                    $schedulePlan[$date][$unitToFix]['afternoon'] = [];
                }
            }
        }
        
        // Additional validation for shift sequence rules
        $this->validateShiftSequenceRules($schedulePlan);
    }
    
    /**
     * Validate and fix any cases where shift sequence rules are violated
     * 
     * @param array $schedulePlan The generated schedule plan
     * @return void
     */
    private function validateShiftSequenceRules(array &$schedulePlan): void
    {
        Log::info("Validating shift sequence rules based on specific pattern");
        
        // Sort dates to ensure chronological processing
        ksort($schedulePlan);
        $dates = array_keys($schedulePlan);
        
        if (empty($dates)) {
            Log::warning("No dates in schedule plan, skipping validation");
            return;
        }
        
        // Build complete driver shift history and identify driver types
        $driverShiftHistory = [];
        $driverTypes = [];
        
        foreach ($dates as $date) {
            $unitPlans = $schedulePlan[$date];
            
            foreach ($unitPlans as $unitId => $shifts) {
                foreach (['morning' => 'pagi', 'afternoon' => 'siang'] as $shiftKey => $shiftValue) {
                    if (!empty($shifts[$shiftKey]) && isset($shifts[$shiftKey]['driver_id'])) {
                        $driverId = $shifts[$shiftKey]['driver_id'];
                        $driverType = $shifts[$shiftKey]['type'];
                        
                        if (!isset($driverShiftHistory[$driverId])) {
                            $driverShiftHistory[$driverId] = [];
                            $driverTypes[$driverId] = $driverType;
                        }
                        
                        $driverShiftHistory[$driverId][] = [
                            'date' => $date,
                            'shift' => $shiftValue,
                            'unit_id' => $unitId,
                            'shift_key' => $shiftKey
                        ];
                    }
                }
            }
        }
        
        if (empty($driverShiftHistory)) {
            Log::warning("No driver shift history found, skipping validation");
            return;
        }
        
        // Sort each driver's history by date
        foreach ($driverShiftHistory as $driverId => $history) {
            usort($driverShiftHistory[$driverId], function($a, $b) {
                return strcmp($a['date'], $b['date']); // Ascending order
            });
        }
        
        // Define the patterns for each driver type
        $patterns = [
            'batangan' => [
                'pattern1' => ['p', 'p', 's', 'n', 'p'], // Driver 1 pattern
                'pattern2' => ['s', 's', 'n', 'p', 's']  // Driver 2 pattern
            ],
            'cadangan' => [
                'pattern1' => ['n', 'n', 'p', 's', 'n']  // Cadangan pattern
            ]
        ];
        
        // Assign patterns to drivers based on their existing shifts
        $driverPatterns = [];
        foreach ($driverShiftHistory as $driverId => $history) {
            $driverType = $driverTypes[$driverId] ?? 'batangan';
            $driverPatterns[$driverId] = $this->determineDriverPattern($driverId, $driverType, $driverShiftHistory);
        }
        
        Log::info("Assigned patterns to drivers", [
            'driverPatterns' => $driverPatterns
        ]);
        
        // Check if we have any missing shifts that need to be filled
        $this->fillMissingShiftsAccordingToPattern($schedulePlan, $driverPatterns, $patterns, $driverTypes);
    }
    
    /**
     * Fill in missing shifts according to the assigned patterns
     * 
     * @param array $schedulePlan The schedule plan to modify
     * @param array $driverPatterns The assigned pattern for each driver
     * @param array $patterns The defined patterns
     * @param array $driverTypes The type of each driver
     * @return void
     */
    private function fillMissingShiftsAccordingToPattern(array &$schedulePlan, array $driverPatterns, array $patterns, array $driverTypes): void
    {
        Log::info("Filling missing shifts according to pattern");
        
        // First, identify all available drivers by type and unit
        $availableDriversByUnit = [];
        
        // Get all unit IDs from the schedule plan
        $unitIds = [];
        foreach ($schedulePlan as $date => $unitPlans) {
            foreach ($unitPlans as $unitId => $shifts) {
                if (!in_array($unitId, $unitIds)) {
                    $unitIds[] = $unitId;
                }
            }
        }
        
        // Initialize available drivers for each unit
        foreach ($unitIds as $unitId) {
            $availableDriversByUnit[$unitId] = [
                'batangan' => [],
                'cadangan' => []
            ];
        }
        
        // Assign drivers to their units
        foreach ($driverTypes as $driverId => $type) {
            // In a real implementation, we would check which units this driver is assigned to
            // For simplicity, we'll assign each driver to all units
            foreach ($unitIds as $unitId) {
                $availableDriversByUnit[$unitId][$type][] = $driverId;
            }
        }
        
        // Sort dates to ensure chronological processing
        ksort($schedulePlan);
        $dates = array_keys($schedulePlan);
        
        // For each date, check if shifts need to be filled
        foreach ($dates as $date) {
            $dayIndex = $this->getDayIndexInPeriod($date);
            Log::info("Processing date $date (day index $dayIndex)");
            
            // Process each unit
            foreach ($schedulePlan[$date] as $unitId => $shifts) {
                // Check morning shift
                if (empty($shifts['morning']) || !isset($shifts['morning']['driver_id'])) {
                    Log::info("Morning shift is empty for unit $unitId on $date");
                    // Find a driver who should have a 'pagi' shift on this day
                    $this->assignDriverForShift($schedulePlan, $date, $unitId, 'morning', 'pagi', $dayIndex, $driverPatterns, $patterns, $availableDriversByUnit[$unitId]);
                }
                
                // Check afternoon shift
                if (empty($shifts['afternoon']) || !isset($shifts['afternoon']['driver_id'])) {
                    Log::info("Afternoon shift is empty for unit $unitId on $date");
                    // Find a driver who should have a 'siang' shift on this day
                    $this->assignDriverForShift($schedulePlan, $date, $unitId, 'afternoon', 'siang', $dayIndex, $driverPatterns, $patterns, $availableDriversByUnit[$unitId]);
                }
            }
        }
        
        // Final check to ensure all drivers follow their patterns
        $this->ensureDriversFollowPattern($schedulePlan, $driverPatterns, $patterns, $driverTypes);
    }
    
    /**
     * Ensure all drivers follow their assigned patterns
     * 
     * @param array $schedulePlan The schedule plan to modify
     * @param array $driverPatterns The assigned pattern for each driver
     * @param array $patterns The defined patterns
     * @param array $driverTypes The type of each driver
     * @return void
     */
    private function ensureDriversFollowPattern(array &$schedulePlan, array $driverPatterns, array $patterns, array $driverTypes): void
    {
        // Build a map of which drivers should have which shifts on which dates
        $expectedShifts = [];
        
        // Sort dates to ensure chronological processing
        ksort($schedulePlan);
        $dates = array_keys($schedulePlan);
        
        foreach ($driverPatterns as $driverId => $patternKey) {
            $driverType = $driverTypes[$driverId] ?? 'batangan';
            $pattern = $patterns[$driverType][$patternKey] ?? [];
            
            foreach ($dates as $date) {
                $dayIndex = $this->getDayIndexInPeriod($date);
                $expectedShift = $pattern[$dayIndex - 1] ?? 'n'; // Pattern is 0-indexed
                
                if ($expectedShift !== 'n') {
                    if (!isset($expectedShifts[$date])) {
                        $expectedShifts[$date] = [];
                    }
                    
                    $expectedShifts[$date][$driverId] = [
                        'shift' => $expectedShift,
                        'type' => $driverType
                    ];
                }
            }
        }
        
        // Check if all expected shifts are assigned
        foreach ($expectedShifts as $date => $drivers) {
            foreach ($drivers as $driverId => $info) {
                $isAssigned = false;
                
                // Check if this driver is assigned on this date
                foreach ($schedulePlan[$date] as $unitId => $shifts) {
                    foreach (['morning' => 'pagi', 'afternoon' => 'siang'] as $shiftKey => $shiftValue) {
                        if (!empty($shifts[$shiftKey]) && isset($shifts[$shiftKey]['driver_id']) && $shifts[$shiftKey]['driver_id'] === $driverId) {
                            $isAssigned = true;
                            break 2;
                        }
                    }
                }
                
                // If driver should have a shift but doesn't, try to assign them
                if (!$isAssigned) {
                    Log::info("Driver $driverId should have {$info['shift']} shift on $date but is not assigned");
                    
                    // Find a unit where this driver can be assigned
                    foreach ($schedulePlan[$date] as $unitId => $shifts) {
                        $shiftKey = ($info['shift'] === 'pagi') ? 'morning' : 'afternoon';
                        
                        // If this shift is empty, assign the driver
                        if (empty($shifts[$shiftKey]) || !isset($shifts[$shiftKey]['driver_id'])) {
                            Log::info("Assigning driver $driverId to {$info['shift']} shift on $date for unit $unitId");
                            $schedulePlan[$date][$unitId][$shiftKey] = [
                                'driver_id' => $driverId,
                                'type' => $info['type']
                            ];
                            break;
                        }
                    }
                }
            }
        }
    }
    
    /**
     * Assign a driver for a specific shift based on patterns
     * 
     * @param array $schedulePlan The schedule plan to modify
     * @param string $date The date
     * @param int $unitId The unit ID
     * @param string $shiftKey The shift key ('morning', 'afternoon')
     * @param string $shiftValue The shift value ('pagi', 'siang')
     * @param int $dayIndex The day index in the pattern (1-5)
     * @param array $driverPatterns The assigned pattern for each driver
     * @param array $patterns The defined patterns
     * @param array $availableDrivers Available drivers by type for this unit
     * @return void
     */
    private function assignDriverForShift(array &$schedulePlan, string $date, int $unitId, string $shiftKey, string $shiftValue, int $dayIndex, array $driverPatterns, array $patterns, array $availableDrivers): void
    {
        // First try batangan drivers
        foreach ($availableDrivers['batangan'] as $driverId) {
            $patternKey = $driverPatterns[$driverId] ?? 'pattern1';
            $pattern = $patterns['batangan'][$patternKey] ?? [];
            $expectedShift = $pattern[$dayIndex - 1] ?? 'n'; // Pattern is 0-indexed
            
            // If this driver should have this shift on this day
            if ($expectedShift === $shiftValue) {
                // Check if driver is already assigned on this date
                if ($this->isDriverAssignedOnDate($schedulePlan, $date, $driverId)) {
                    Log::info("Driver $driverId already assigned on $date, skipping");
                    continue;
                }
                
                // Assign this driver
                Log::info("Assigning batangan driver $driverId to $shiftValue shift on $date (day $dayIndex) based on pattern");
                $schedulePlan[$date][$unitId][$shiftKey] = [
                    'driver_id' => $driverId,
                    'type' => 'batangan'
                ];
                return;
            }
        }
        
        // Then try cadangan drivers
        foreach ($availableDrivers['cadangan'] as $driverId) {
            $patternKey = $driverPatterns[$driverId] ?? 'pattern1';
            $pattern = $patterns['cadangan'][$patternKey] ?? [];
            $expectedShift = $pattern[$dayIndex - 1] ?? 'n'; // Pattern is 0-indexed
            
            // If this driver should have this shift on this day
            if ($expectedShift === $shiftValue) {
                // Check if driver is already assigned on this date
                if ($this->isDriverAssignedOnDate($schedulePlan, $date, $driverId)) {
                    Log::info("Driver $driverId already assigned on $date, skipping");
                    continue;
                }
                
                // Assign this driver
                Log::info("Assigning cadangan driver $driverId to $shiftValue shift on $date (day $dayIndex) based on pattern");
                $schedulePlan[$date][$unitId][$shiftKey] = [
                    'driver_id' => $driverId,
                    'type' => 'cadangan'
                ];
                return;
            }
        }
        
        // If no driver matches the pattern exactly, try to find any available driver
        Log::info("No driver matches pattern for $shiftValue on $date (day $dayIndex), trying any available driver");
        
        // Try batangan drivers first
        foreach ($availableDrivers['batangan'] as $driverId) {
            // Check if driver is already assigned on this date
            if ($this->isDriverAssignedOnDate($schedulePlan, $date, $driverId)) {
                continue;
            }
            
            // Assign this driver
            Log::info("Assigning any available batangan driver $driverId to $shiftValue shift on $date");
            $schedulePlan[$date][$unitId][$shiftKey] = [
                'driver_id' => $driverId,
                'type' => 'batangan'
            ];
            return;
        }
        
        // Then try cadangan drivers
        foreach ($availableDrivers['cadangan'] as $driverId) {
            // Check if driver is already assigned on this date
            if ($this->isDriverAssignedOnDate($schedulePlan, $date, $driverId)) {
                continue;
            }
            
            // Assign this driver
            Log::info("Assigning any available cadangan driver $driverId to $shiftValue shift on $date");
            $schedulePlan[$date][$unitId][$shiftKey] = [
                'driver_id' => $driverId,
                'type' => 'cadangan'
            ];
            return;
        }
        
        Log::warning("Could not find any available driver for $shiftValue shift on $date for unit $unitId");
    }
    
    /**
     * Check if a driver is already assigned on a specific date
     * 
     * @param array $schedulePlan The schedule plan
     * @param string $date The date to check
     * @param int $driverId The driver ID
     * @return bool True if driver is already assigned, false otherwise
     */
    private function isDriverAssignedOnDate(array $schedulePlan, string $date, int $driverId): bool
    {
        if (!isset($schedulePlan[$date])) {
            return false;
        }
        
        foreach ($schedulePlan[$date] as $unitId => $shifts) {
            foreach (['morning', 'afternoon'] as $shiftKey) {
                if (!empty($shifts[$shiftKey]) && isset($shifts[$shiftKey]['driver_id']) && $shifts[$shiftKey]['driver_id'] === $driverId) {
                    return true;
                }
            }
        }
        
        return false;
    }
    
    /**
     * Ensure cadangan drivers are assigned enough shifts
     * 
     * @param array $schedulePlan The schedule plan to modify
     * @return void
     */
    private function ensureCadanganDriverAssignments(array &$schedulePlan): void
    {
        // Count assignments for each driver type
        $driverAssignments = [];
        $driverTypes = [];
        $unassignedShifts = [];
        
        // First pass: Count assignments and identify unassigned shifts
        foreach ($schedulePlan as $date => $unitPlans) {
            foreach ($unitPlans as $unitId => $shifts) {
                foreach (['morning' => 'pagi', 'afternoon' => 'siang'] as $shiftKey => $shiftValue) {
                    if (empty($shifts[$shiftKey]) || !isset($shifts[$shiftKey]['driver_id'])) {
                        // This is an unassigned shift
                        $unassignedShifts[] = [
                            'date' => $date,
                            'unit_id' => $unitId,
                            'shift_key' => $shiftKey,
                            'shift_value' => $shiftValue
                        ];
                    } else {
                        $driverId = $shifts[$shiftKey]['driver_id'];
                        $driverType = $shifts[$shiftKey]['type'];
                        
                        if (!isset($driverAssignments[$driverId])) {
                            $driverAssignments[$driverId] = 0;
                            $driverTypes[$driverId] = $driverType;
                        }
                        
                        $driverAssignments[$driverId]++;
                    }
                }
            }
        }
        
        // Find cadangan drivers with fewer than 2 shifts
        $underassignedCadangan = [];
        foreach ($driverAssignments as $driverId => $count) {
            if ($driverTypes[$driverId] === 'cadangan' && $count < 2) {
                $underassignedCadangan[$driverId] = $count;
            }
        }
        
        // Sort by number of assignments (ascending)
        asort($underassignedCadangan);
        
        // Try to assign unassigned shifts to cadangan drivers
        foreach ($underassignedCadangan as $driverId => $currentCount) {
            $neededShifts = 2 - $currentCount;
            $assignedDates = $this->getDriverAssignedDates($driverId, $schedulePlan);
            
            for ($i = 0; $i < count($unassignedShifts) && $neededShifts > 0; $i++) {
                $shift = $unassignedShifts[$i];
                
                // Skip if driver already has a shift on this date
                if (in_array($shift['date'], $assignedDates)) {
                    continue;
                }
                
                // Assign this shift to the cadangan driver
                Log::info("Assigning unassigned shift to cadangan driver $driverId: {$shift['date']} {$shift['shift_value']}");
                $schedulePlan[$shift['date']][$shift['unit_id']][$shift['shift_key']] = [
                    'driver_id' => $driverId,
                    'type' => 'cadangan'
                ];
                
                // Update tracking
                $assignedDates[] = $shift['date'];
                $neededShifts--;
                array_splice($unassignedShifts, $i, 1);
                $i--; // Adjust index since we removed an element
            }
        }
    }
    
    /**
     * Get the dates a driver is assigned to
     * 
     * @param int $driverId The driver ID
     * @param array $schedulePlan The schedule plan
     * @return array Array of dates the driver is assigned to
     */
    private function getDriverAssignedDates(int $driverId, array $schedulePlan): array
    {
        $assignedDates = [];
        
        foreach ($schedulePlan as $date => $unitPlans) {
            foreach ($unitPlans as $unitId => $shifts) {
                foreach (['morning', 'afternoon'] as $shiftKey) {
                    if (!empty($shifts[$shiftKey]) && isset($shifts[$shiftKey]['driver_id']) && $shifts[$shiftKey]['driver_id'] === $driverId) {
                        $assignedDates[] = $date;
                        break 2; // Break out of both loops once we find an assignment for this date
                    }
                }
            }
        }
        
        return $assignedDates;
    }
    
    private function scoreDriverOption(
        int $driverId,
        string $shift,
        array $driverScheduleCounts,
        array $lastShiftByDriver
    ): float {
        $score = 100;
        $stats = $driverScheduleCounts[$driverId];
        
        // Prioritize drivers with fewer total assignments
        $score -= ($stats['total'] * 10);
        
        // Prioritize consistent shift patterns
        if ($shift === 'pagi') {
            // For morning shifts, prioritize drivers with more morning shifts
            $score += ($stats['morning'] * 5);
            $score -= ($stats['afternoon'] * 5);
        } else {
            // For afternoon shifts, prioritize drivers with more afternoon shifts
            $score += ($stats['afternoon'] * 5);
            $score -= ($stats['morning'] * 5);
        }
        
        // Bonus for new drivers
        if ($lastShiftByDriver[$driverId] === null) {
            $score += 30;
        }
        
        // Bonus for maintaining the same shift type
        if ($lastShiftByDriver[$driverId] === $shift) {
            $score += 25;
        }
        
        return $score;
    }

    private function findAvailableDriverForShift(
        int $unitId, 
        string $date,
        string $shift,
        array $schedulePlan,
        array $driverCounts
    ): ?array {
        $availableDrivers = [];
        
        foreach ($driverCounts as $driverId => $info) {
            // Skip if driver is already assigned on this date and shift
            if (isset($schedulePlan[$date][$unitId][$shift]['driver_id']) 
                && $schedulePlan[$date][$unitId][$shift]['driver_id'] === $driverId) {
                continue;
            }
            
            // Check if driver is under their limit
            $maxShifts = $info['type'] === 'batangan' ? 14 : 11;
            if ($info['count'] < $maxShifts && in_array($unitId, $info['units'])) {
                $availableDrivers[] = [
                    'id' => $driverId,
                    'driver_id' => $driverId,
                    'type' => $info['type'],
                    'count' => $info['count']
                ];
            }
        }
        
        // Sort by least assigned shifts
        usort($availableDrivers, function($a, $b) {
            return $a['count'] <=> $b['count'];
        });
        
        return !empty($availableDrivers) ? $availableDrivers[0] : null;
    }

    private function findReplacementDriver(
        int $unitId,
        string $date,
        string $shift,
        string $type,
        array $schedulePlan,
        array $driverCounts
    ): ?array {
        $candidates = [];
        
        foreach ($driverCounts as $driverId => $info) {
            // Only consider drivers of the same type with fewer shifts
            if ($info['type'] === $type && $info['count'] < ($type === 'batangan' ? 14 : 11)) {
                // Skip if driver is already assigned on this date and shift
                if (isset($schedulePlan[$date][$unitId][$shift]['driver_id']) 
                    && $schedulePlan[$date][$unitId][$shift]['driver_id'] === $driverId) {
                    continue;
                }
                
                // Check if driver is authorized for this unit
                if (in_array($unitId, $info['units'])) {
                    $candidates[] = [
                        'id' => $driverId,
                        'driver_id' => $driverId,
                        'type' => $type,
                        'count' => $info['count']
                    ];
                }
            }
        }
        
        // Sort by least assigned shifts
        usort($candidates, function($a, $b) {
            return $a['count'] <=> $b['count'];
        });
        
        return !empty($candidates) ? $candidates[0] : null;
    }

    private function balanceShifts(array &$schedulePlan, array &$driverScheduleCounts): void
    {
        foreach ($schedulePlan as $date => $unitPlans) {
            foreach ($unitPlans as $unitId => $shifts) {
                foreach (['pagi', 'siang'] as $shift) {
                    if (!isset($shifts[$shift]['driver_id'])) {
                        continue;
                    }

                    $driverId = $shifts[$shift]['driver_id'];
                    if (!isset($driverScheduleCounts[$driverId])) {
                        continue;
                    }
                    
                    $driverStats = $driverScheduleCounts[$driverId];
                    
                    // Check for significant imbalance (more than 2 shifts difference)
                    if ($shift === 'pagi' && $driverStats['morning'] > $driverStats['afternoon'] + 2) {
                        // Look for a driver with more afternoon shifts to swap with
                        foreach ($driverScheduleCounts as $otherDriverId => $otherStats) {
                            if ($otherDriverId === $driverId) continue;
                            
                            if ($otherStats['afternoon'] > $otherStats['morning'] 
                                && isset($shifts['siang']['driver_id'])
                                && $shifts['siang']['driver_id'] !== $otherDriverId) {
                                
                                // Swap the shifts
                                $tempMorning = $shifts['pagi'];
                                $schedulePlan[$date][$unitId]['pagi'] = [
                                    'driver_id' => $otherDriverId,
                                    'type' => $driverScheduleCounts[$otherDriverId]['type']
                                ];
                                
                                // Update counts
                                $driverScheduleCounts[$driverId]['morning']--;
                                $driverScheduleCounts[$otherDriverId]['morning']++;
                                break;
                            }
                        }
                    } elseif ($shift === 'siang' && $driverStats['afternoon'] > $driverStats['morning'] + 2) {
                        // Look for a driver with more morning shifts to swap with
                        foreach ($driverScheduleCounts as $otherDriverId => $otherStats) {
                            if ($otherDriverId === $driverId) continue;
                            
                            if ($otherStats['morning'] > $otherStats['afternoon']
                                && isset($shifts['pagi']['driver_id'])
                                && $shifts['pagi']['driver_id'] !== $otherDriverId) {
                                
                                // Swap the shifts
                                $tempAfternoon = $shifts['siang'];
                                $schedulePlan[$date][$unitId]['siang'] = [
                                    'driver_id' => $otherDriverId,
                                    'type' => $driverScheduleCounts[$otherDriverId]['type']
                                ];
                                
                                // Update counts
                                $driverScheduleCounts[$driverId]['afternoon']--;
                                $driverScheduleCounts[$otherDriverId]['afternoon']++;
                                break;
                            }
                        }
                    }
                }
            }
        }
    }
}