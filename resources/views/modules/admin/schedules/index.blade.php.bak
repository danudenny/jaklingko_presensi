                    </div>
                    <div>
                        <nav class="relative z-0 inline-flex -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                            {{-- Previous Page Link --}}
                            @if ($schedules->onFirstPage())
                                <span class="relative inline-flex items-center px-2 py-2 text-sm font-medium text-gray-300 bg-white border border-gray-300 rounded-l-md">
                                    <span class="sr-only">Previous</span>
                                    <i class="fas fa-chevron-left"></i>
                                </span>
                            @else
                                <a href="{{ $schedules->previousPageUrl() }}" class="relative inline-flex items-center px-2 py-2 text-sm font-medium text-gray-500 bg-white border border-gray-300 rounded-l-md hover:bg-gray-50">
                                    <span class="sr-only">Previous</span>
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            @endif

                            {{-- Pagination Elements --}}
                            @foreach ($schedules->onEachSide(1)->links()->elements[0] as $page => $url)
                                @if ($page == $schedules->currentPage())
                                    <span class="relative inline-flex items-center px-4 py-2 text-sm font-medium text-blue-600 border border-gray-300 bg-blue-50">
                                        {{ $page }}
                                    </span>
                                @else
                                    <a href="{{ $url }}" class="relative inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 hover:bg-gray-50">
                                        {{ $page }}
                                    </a>
                                @endif
                            @endforeach

                            {{-- Next Page Link --}}
                            @if ($schedules->hasMorePages())
                                <a href="{{ $schedules->nextPageUrl() }}" class="relative inline-flex items-center px-2 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-r-md hover:bg-gray-50">
                                    <span class="sr-only">Next</span>
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            @else
                                <span class="relative inline-flex items-center px-2 py-2 text-sm font-medium text-gray-300 bg-white border border-gray-300 rounded-r-md">
                                    <span class="sr-only">Next</span>
                                    <i class="fas fa-chevron-right"></i>
                                </span>
                            @endif
                        </nav>
                    </div>
                </div>
            </div>
        @endif
    </x-card>
</div>
@endsection

@push('scripts')
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
    $(document).ready(function() {
        function formatDate(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function formatDisplayDate(date) {
            const day = String(date.getDate()).padStart(2, '0');
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const year = date.getFullYear();
            return `${day}/${month}/${year}`;
        }

        const initialStartDate = $("#start_date").val() ? new Date($("#start_date").val()) : new Date();
        const initialEndDate = $("#end_date").val() ? new Date($("#end_date").val()) : new Date();

        if (initialStartDate && initialEndDate) {
            const formattedStartDate = formatDisplayDate(initialStartDate);
            const formattedEndDate = formatDisplayDate(initialEndDate);

            if (formattedStartDate === formattedEndDate) {
                $("#date-range").val(formattedStartDate);
            } else {
                $("#date-range").val(formattedStartDate + " - " + formattedEndDate);
            }
        }

        const fp = flatpickr("#date-range", {
            mode: "range",
            dateFormat: "d/m/Y",
            defaultDate: [initialStartDate, initialEndDate],
            maxRange: 30,
            disableMobile: true,
            allowInput: false,
            onChange: function(selectedDates, dateStr, instance) {
                if (selectedDates.length === 1) {
                    const formattedDate = formatDisplayDate(selectedDates[0]);
                    $("#date-range").val(formattedDate);
                } else if (selectedDates.length === 2) {
                    const formattedStartDate = formatDisplayDate(selectedDates[0]);
                    const formattedEndDate = formatDisplayDate(selectedDates[1]);

                    if (formattedStartDate === formattedEndDate) {
                        $("#date-range").val(formattedStartDate);
                    } else {
                        $("#date-range").val(formattedStartDate + " - " + formattedEndDate);
                    }
                }
            },
            onClose: function(selectedDates, dateStr, instance) {
                if (selectedDates.length === 2) {
                    const diffTime = Math.abs(selectedDates[1] - selectedDates[0]);
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                    if (diffDays > 30) {
                        const maxDate = new Date(selectedDates[0]);
                        maxDate.setDate(maxDate.getDate() + 30);
                        instance.setDate([selectedDates[0], maxDate]);
                        alert("Maximum date range is 30 days. End date has been adjusted.");
                        selectedDates[1] = maxDate;
                    }

                    $("#start_date").val(formatDate(selectedDates[0]));
                    $("#end_date").val(formatDate(selectedDates[1]));

                    $("#filter-form").submit();
                } else if (selectedDates.length === 1) {
                    $("#start_date").val(formatDate(selectedDates[0]));
                    $("#end_date").val(formatDate(selectedDates[0]));

                    $("#filter-form").submit();
                }
            }
        });

        $('.date-preset').on('click', function(e) {
            e.preventDefault();
            const days = parseInt($(this).data('days'));

            const adjustedDays = Math.min(days, 30);

            const today = new Date();
            const futureDate = new Date();
            futureDate.setDate(today.getDate() + adjustedDays);

            $("#start_date").val(formatDate(today));
            $("#end_date").val(formatDate(futureDate));

            fp.setDate([today, futureDate]);
            $("#filter-form").submit();

            return false;
        });
        
        // Matrix export modal
        const matrixDatePicker = flatpickr("#matrix-date", {
            dateFormat: "Y-m-d",
            defaultDate: new Date(),
            maxDate: new Date().fp_incr(30),
            locale: {
                firstDayOfWeek: 1
            }
        });
        
        // Open matrix export modal
        $('#open-matrix-export-modal').on('click', function(e) {
            e.preventDefault();
            $('#matrix-export-modal').removeClass('hidden');
        });
        
        // Close matrix export modal
        $('.close-matrix-modal').on('click', function(e) {
            e.preventDefault();
            $('#matrix-export-modal').addClass('hidden');
        });
        
        // Export matrix PDF
        $('#export-matrix-pdf').on('click', function(e) {
            e.preventDefault();
            const month = $('#matrix-month').val();
            const year = $('#matrix-year').val();
            const period = $('#matrix-period').val();
            
            if (month && year) {
                $('#loading-overlay').addClass('active');
                $('#loading-text').text('Generating PDF...');
                
                let url = "{{ route('schedules.export.matrix-pdf') }}?month=" + month + "&year=" + year;
                if (period) {
                    url += "&period=" + period;
                }
                
                const downloadFrame = document.createElement('iframe');
                downloadFrame.style.display = 'none';
                document.body.appendChild(downloadFrame);
                
                const loadingTimeout = setTimeout(function() {
                    $('#loading-overlay').removeClass('active');
                }, 10000);
                
                downloadFrame.onload = function() {
                    clearTimeout(loadingTimeout);
                    setTimeout(function() {
                        $('#loading-overlay').removeClass('active');
                    }, 1000);
                };
                
                downloadFrame.src = url;
                
                $('#matrix-export-modal').addClass('hidden');
            } else {
                alert('Please select month and year');
            }
        });
        
        $('a[href*="export/pdf"], a[href*="export/excel"]').on('click', function(e) {
            e.preventDefault();
            
            $('#loading-overlay').addClass('active');
            
            if ($(this).attr('href').includes('excel')) {
                $('#loading-text').text('Generating Excel...');
            } else {
                $('#loading-text').text('Generating PDF...');
            }
            
            const downloadFrame = document.createElement('iframe');
            downloadFrame.style.display = 'none';
            document.body.appendChild(downloadFrame);
            
            const loadingTimeout = setTimeout(function() {
                $('#loading-overlay').removeClass('active');
            }, 10000); 
            
            downloadFrame.onload = function() {
                clearTimeout(loadingTimeout);
                setTimeout(function() {
                    $('#loading-overlay').removeClass('active');
                }, 1000);
            };

            downloadFrame.src = $(this).attr('href');
        });

        $('#list-view-btn').on('click', function() {
            $('#matrix-view').hide();
            $('#list-view').show();
            $('#list-view-btn').addClass('bg-indigo-600 text-white');
            $('#matrix-view-btn').removeClass('bg-indigo-600 text-white').addClass('bg-white text-gray-700');
        });

        $('#matrix-view-btn').on('click', function() {
            $('#list-view').hide();
            $('#matrix-view').show();
            $('#matrix-view-btn').addClass('bg-indigo-600 text-white');
            $('#list-view-btn').removeClass('bg-indigo-600 text-white').addClass('bg-white text-gray-700');

            if (typeof loadMatrixData === 'function') {
                loadMatrixData(true); 
            }
        });

        $('.period-tab').on('click', function() {
            $('.period-tab').removeClass('active');
            $(this).addClass('active');
            $('#period-' + activePeriod + ' .matrix-checkbox:checked').each(function() {
                matrix.push({
                    unit_id: $(this).data('unit'),
                    date: $(this).data('date'),
                    shift: $(this).closest('tr').find('td:nth-child(4) span').text().trim().toLowerCase() === 'pagi' ? 'pagi' : 'siang'
                });
            });
            
            if (matrix.length === 0) {
                alert('No schedules selected');
                return;
            }
            
            const button = $(this);
            const originalHtml = button.html();
            button.html('<i class="mr-2 fas fa-spinner fa-spin"></i> Saving...');
            button.prop('disabled', true);
            
            $.ajax({
                url: '{{ route("schedules.save-matrix") }}',
                type: 'POST',
                headers: {
                    'X-CSRF-TOKEN': '{{ csrf_token() }}'
                },
                data: JSON.stringify({
                    matrix: matrix
                }),
                contentType: 'application/json',
                success: function(response) {
                    if (response.success) {
                        alert('Schedules saved successfully');
                    } else {
                        alert('Error saving schedules: ' + response.message);
                    }
                },
                error: function() {
                    alert('Error saving schedules');
                },
                complete: function() {
                    button.html(originalHtml);
                    button.prop('disabled', false);
                }
            });
        });
        
        function loadMatrixData() {
            const now = new Date();
            const month = now.getMonth() + 1;
            const year = now.getFullYear();
            
            $('#matrix-view').prepend('<div class="flex justify-center p-4"><i class="mr-2 fas fa-spinner fa-spin"></i> Loading schedules...</div>');
            
            $.ajax({
                url: '{{ route("schedules.matrix-data") }}',
                type: 'GET',
                data: {
                    month: month,
                    year: year
                },
                success: function(data) {
                    $('#matrix-view > div:first-child').remove();
                    
                    if (data.success) {
                        updateMatrixView(data.period1, 1, month, year);
                        updateMatrixView(data.period2, 2, month, year);
                    } else {
                        $('#matrix-view').prepend('<div class="p-4 mb-4 text-red-700 bg-red-100 rounded">Failed to load schedule data: ' + (data.message || 'Unknown error') + '</div>');
                    }
                },
                error: function(xhr) {
                    $('#matrix-view > div:first-child').remove();
                    $('#matrix-view').prepend('<div class="p-4 mb-4 text-red-700 bg-red-100 rounded">Failed to load schedule data. Please try again later.</div>');
                    console.error('Error loading matrix data:', xhr.responseText);
                }
            });
        }
        
        function updateMatrixView(data, period, month, year) {
            $('#period-' + period + ' tbody').empty();
            const routeGroups = {};
            
            if (data && data.length > 0) {
                data.forEach(function(row) {
                    const routeNumber = row.route.route_number || 'Unknown Route';
                    if (!routeGroups[routeNumber]) {
                        routeGroups[routeNumber] = {
                            routeName: row.route.name,
                            rows: []
                        };
                    }
                    routeGroups[routeNumber].rows.push(row);
                });
                
                Object.keys(routeGroups).sort().forEach(function(routeNumber) {
                    const routeGroup = routeGroups[routeNumber];
                    
                    const startDay = period === 1 ? 1 : 16;
                    const endDay = period === 1 ? 15 : new Date(year, month, 0).getDate();
                    const colCount = (endDay - startDay + 1) + 5;
                    
                    const routeHeader = $(`
                        <tr class="bg-gray-100">
                            <td colspan="${colCount}" class="z-10 px-6 py-2 text-sm font-bold text-gray-900 bg-gray-100 whitespace-nowrap sticky-left">
                                ${routeNumber} - ${routeGroup.routeName}
                            </td>
                        </tr>
                    `);
                    
                    $('#period-' + period + ' tbody').append(routeHeader);
                    
                    routeGroup.rows.forEach(function(row) {
                        const tr = $('<tr class="border-t border-gray-200 hover:bg-gray-50"></tr>');
                        
                        tr.append(`<td class="z-10 px-4 py-2 text-sm font-medium text-gray-900 bg-white whitespace-nowrap sticky-left hover:bg-gray-50">${row.unit.unit_number}</td>`);
                        tr.append(`<td class="z-10 px-4 py-2 text-sm text-gray-500 bg-white whitespace-nowrap sticky-left hover:bg-gray-50">${routeNumber || ''} - ${routeGroup.routeName}</td>`);
                        tr.append(`<td class="z-10 px-4 py-2 text-sm text-gray-500 bg-white whitespace-nowrap sticky-left hover:bg-gray-50">${row.driver.name}</td>`);
                        
                        const shiftClass = row.shift === 'pagi' || row.shift === 'morning' ? 'bg-yellow-100 text-yellow-800' : 'bg-indigo-100 text-indigo-800';
                        const shiftText = row.shift === 'pagi' || row.shift === 'morning' ? 'Pagi' : 'Siang';
                        tr.append(`
                            <td class="z-10 px-4 py-2 text-sm text-center bg-white whitespace-nowrap sticky-left hover:bg-gray-50">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${shiftClass}">
                                    ${shiftText}
                                </span>
                            </td>
                        `);
                        
                        let totalScheduled = 0;
                        
                        const startDay = period === 1 ? 1 : 16;
                        const endDay = period === 1 ? 15 : new Date(year, month, 0).getDate();
                        
                        for (let day = startDay; day <= endDay; day++) {
                            const date = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                            const dateObj = new Date(`${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`);
                            
                            const isWeekend = dateObj.getDay() === 0 || dateObj.getDay() === 6;
                            const cellClass = isWeekend ? 'weekend' : '';
                            
                            let isScheduled = false;
                            if (row.schedules && row.schedules.length > 0) {
                                isScheduled = row.schedules.some(s => {
                                    const scheduleDate = typeof s.schedule_date === 'string' ? s.schedule_date : s.schedule_date.date;
                                    return scheduleDate === date;
                                });
                            }
                            
                            if (isScheduled) {
                                totalScheduled++;
                            }
                            
                            tr.append(`
                                <td class="px-3 py-2 text-sm text-center ${cellClass}">
                                    <input type="checkbox" class="matrix-checkbox" 
                                        data-unit="${row.unit.id}" 
                                        data-driver="${row.driver.id}" 
                                        data-route="${row.route.id}" 
                                        data-date="${date}" 
                                        ${isScheduled ? 'checked' : ''}>
                                </td>
                            `);
                        }
                        
                        tr.append(`
                            <td class="px-4 py-2 text-sm font-bold text-center bg-gray-100">
                                ${totalScheduled}
                            </td>
                        `);
                        
                        $('#period-' + period + ' tbody').append(tr);
                    });
                });
            } else {
                const colCount = period === 1 ? 20 : 20 + (new Date(year, month, 0).getDate() - 15);
                $('#period-' + period + ' tbody').append(`
                    <tr>
                        <td colspan="${colCount}" class="px-6 py-4 text-sm font-medium text-center text-gray-500 whitespace-nowrap bg-yellow-50">
                            <i class="mr-2 fas fa-exclamation-circle"></i>
                            No schedule data available for this period.
                        </td>
                    </tr>
                `);
            }
        }
    });
    
    function setupChainedFiltering() {
        const allUnitOptions = $('#unit_id option').clone();
        const allDriverOptions = $('#driver_id option').clone();
        
        $('#route_id').on('change', function() {
            const selectedRouteId = $(this).val();
            
            $('#unit_id').empty().append(allUnitOptions.clone());
            $('#unit_id').val('');
            
            $('#driver_id').empty().append(allDriverOptions.clone());
            $('#driver_id').val('');
            
            if (selectedRouteId) {
                $('#unit_id').prop('disabled', true);
                
                $.ajax({
                    url: '/schedules/routes/' + selectedRouteId + '/units',
                    type: 'GET',
                    success: function(data) {
                        if (data && data.length > 0) {
                            // Keep only the units that belong to this route
                            $('#unit_id option').each(function() {
                                const unitId = $(this).val();
                                if (unitId && !data.includes(parseInt(unitId))) {
                                    $(this).remove();
                                }
                            });
                        }
                    },
                    error: function() {
                        console.error('Failed to fetch units for route');
                    },
                    complete: function() {
                        $('#unit_id').prop('disabled', false);
                    }
                });
            }
        });
        
        $('#unit_id').on('change', function() {
            const selectedUnitId = $(this).val();
            
            $('#driver_id').empty().append(allDriverOptions.clone());
            $('#driver_id').val('');
            
            if (selectedUnitId) {
                $('#driver_id').prop('disabled', true);
                
                $.ajax({
                    url: '/schedules/units/' + selectedUnitId + '/drivers',
                    type: 'GET',
                    success: function(data) {
                        if (data && data.length > 0) {
                            $('#driver_id option').each(function() {
                                const driverId = $(this).val();
                                if (driverId && !data.includes(parseInt(driverId))) {
                                    $(this).remove();
                                }
                            });
                        }
                    },
                    error: function() {
                        console.error('Failed to fetch drivers for unit');
                    },
                    complete: function() {
                        $('#driver_id').prop('disabled', false);
                    }
                });
            }
        });
        
        $('#filter-form').on('submit', function() {
            $(this).find('select').each(function() {
                if (!$(this).val()) {
                    $(this).prop('disabled', true);
                }
            });
            
            setTimeout(function() {
                $('#filter-form select').prop('disabled', false);
            }, 10);
            
            return true;
        });
        
        if ($('#route_id').val()) {
            $('#route_id').trigger('change');
        }
    }
</script>
@endpush

<!-- Matrix Export Modal -->
<div id="matrix-export-modal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
